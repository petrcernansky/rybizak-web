                <div class="grid gap-8 lg:gap-10 md:grid-cols-2 max-w-5xl mx-auto items-stretch">
                    {menuList.map((menu) => (
                        <article class="group flex h-full flex-col rounded-[2rem] border border-white/70 bg-white p-5 sm:p-6 text-left shadow-[0_24px_80px_rgba(15,23,42,0.08)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_28px_90px_rgba(69,34,94,0.16)]">
                            <div class="mb-6 flex items-start justify-between gap-4">
                                <div>
                                    <p class="text-xs font-semibold uppercase tracking-[0.35em] text-[#ad6cdb] mb-2">
                                        {menu.kind === 'pdf' ? 'PDF nabídka' : 'Obrázková galerie'}
                                    </p>
                                    <h3 class="text-2xl font-bold text-gray-900 leading-tight">
                                        {menu.title}
                                    </h3>
                                </div>
                                <span class="shrink-0 rounded-full bg-[#45225e]/8 px-4 py-2 text-xs font-bold uppercase tracking-[0.25em] text-[#45225e]">
                                    {menu.kind === 'pdf' ? 'PDF' : getPageLabel(menu.pageCount)}
                                </span>
                            </div>

                            {menu.kind === 'pdf' ? (
                                <div class="flex h-full flex-col">
                                    <a href={menu.href} target="_blank" rel="noreferrer" class="block relative w-full aspect-[4/5] overflow-hidden rounded-[1.75rem] border border-[#45225e]/10 bg-gradient-to-br from-[#faf6ff] via-white to-[#efe5ff] p-6 sm:p-8">
                                        <div class="absolute inset-x-0 top-0 h-28 bg-gradient-to-b from-[#45225e]/10 to-transparent"></div>
                                        <div class="relative z-10 flex h-full flex-col justify-between">
                                            <div class="flex items-center justify-between gap-4">
                                                <div class="rounded-2xl bg-[#45225e] px-4 py-3 text-left text-white shadow-lg">
                                                    <div class="text-[11px] uppercase tracking-[0.35em] text-white/70">Dokument</div>
                                                    <div class="text-xl font-bold">PDF</div>
                                                </div>
                                                <div class="rounded-full border border-[#45225e]/15 bg-white/80 px-4 py-2 text-xs font-semibold uppercase tracking-[0.3em] text-[#45225e]">
                                                    Otevřít
                                                </div>
                                            </div>

                                            <div class="mx-auto w-full max-w-[16rem] rounded-[1.5rem] border border-white/80 bg-white/95 p-5 shadow-[0_20px_60px_rgba(69,34,94,0.12)]">
                                                <div class="mb-4 flex items-center justify-between">
                                                    <div class="h-3 w-16 rounded-full bg-[#45225e]/15"></div>
                                                    <div class="h-3 w-10 rounded-full bg-[#ad6cdb]/20"></div>
                                                </div>
                                                <div class="space-y-3">
                                                    <div class="h-3 rounded-full bg-slate-200"></div>
                                                    <div class="h-3 w-11/12 rounded-full bg-slate-200"></div>
                                                    <div class="h-3 w-4/5 rounded-full bg-slate-200"></div>
                                                    <div class="h-20 rounded-[1.25rem] bg-gradient-to-br from-[#45225e]/10 via-[#ad6cdb]/15 to-[#45225e]/5"></div>
                                                    <div class="h-3 w-10/12 rounded-full bg-slate-200"></div>
                                                    <div class="h-3 w-2/3 rounded-full bg-slate-200"></div>
                                                </div>
                                            </div>

                                            <div class="text-sm text-slate-600 leading-relaxed">
                                                Vícestránkové PDF otevřete jedním kliknutím v novém okně. Na mobilu funguje stejně spolehlivě jako na desktopu.
                                            </div>
                                        </div>
                                    </a>

                                    <div class="mt-5 flex flex-col sm:flex-row gap-3">
                                        <a href={menu.href} target="_blank" rel="noreferrer" class="inline-flex flex-1 items-center justify-center rounded-full bg-[#45225e] px-5 py-3 text-sm font-bold text-white transition hover:bg-[#5b2d7a]">
                                            Otevřít PDF
                                        </a>
                                        <a href={menu.href} download class="inline-flex flex-1 items-center justify-center rounded-full border border-[#45225e]/15 px-5 py-3 text-sm font-bold text-[#45225e] transition hover:border-[#45225e]/30 hover:bg-[#45225e]/5">
                                            Stáhnout
                                        </a>
                                    </div>
                                </div>
                            ) : (
                                <div class="flex h-full flex-col">
                                    <div class="relative w-full aspect-[4/5]">
                                        <a data-fslightbox={`gallery-${menu.slug}`} href={menu.href} class="block relative w-full h-full">
                                            {menu.pageCount > 1 && (
                                                <div class="absolute inset-0 bg-white rounded-[1.75rem] shadow-md border border-gray-200 transform translate-x-3 translate-y-3 rotate-3 transition duration-300 group-hover:translate-x-4 group-hover:translate-y-4 group-hover:rotate-6 z-0"></div>
                                            )}
                                            {menu.pageCount > 2 && (
                                                <div class="absolute inset-0 bg-white rounded-[1.75rem] shadow-md border border-gray-200 transform -translate-x-2 translate-y-2 -rotate-2 transition duration-300 group-hover:-translate-x-3 group-hover:translate-y-3 group-hover:-rotate-4 z-0"></div>
                                            )}
                                            <div class="relative z-10 w-full h-full bg-white rounded-[1.75rem] shadow-xl overflow-hidden border border-gray-100 transition duration-300 transform group-hover:-translate-y-1">
                                                <img src={menu.images[0]} alt={menu.title} class="w-full h-full object-cover" />
                                                <div class="absolute inset-0 bg-gradient-to-t from-black/35 via-black/0 to-black/0"></div>
                                                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition duration-300 flex items-center justify-center">
                                                    <span class="opacity-0 group-hover:opacity-100 bg-[#45225e] text-white px-4 py-2 rounded-full font-bold shadow-lg transform translate-y-4 group-hover:translate-y-0 transition duration-300">
                                                        Prohlédnout
                                                    </span>
                                                </div>
                                            </div>
                                        </a>
                                        {menu.pageCount > 1 && (
                                            <div class="absolute -top-3 -right-3 z-20 bg-[#45225e] text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg border-2 border-white">
                                                {getPageLabel(menu.pageCount)}
                                            </div>
                                        )}
                                        {menu.images.slice(1).map((img) => (
                                            <a data-fslightbox={`gallery-${menu.slug}`} href={img} class="hidden"></a>
                                        ))}
                                    </div>

                                    <p class="mt-5 text-sm text-slate-600 leading-relaxed">
                                        Otevře se celá nabídka ve světloboxu, takže si ji host snadno projde i na telefonu.
                                    </p>
                                </div>
                            )}
                        </article>
                    ))}
                </div>
            </div>
        </section>
    )}

    {hasEvents && (
        <section id="akce" class="py-24 bg-white">
            <div class="max-w-7xl mx-auto px-4 text-center">
                <h2 class="text-3xl font-bold text-[#45225e] mb-12">Co chystáme?</h2>
                <div class="flex flex-wrap justify-center gap-8">
                    {plakaty.map((akce) => (
                        akce.data.poster && (
                            <div class="group relative w-full max-w-md">
                                <img src={akce.data.poster} alt={akce.data.title} class="w-full h-auto rounded-lg shadow-lg group-hover:shadow-2xl transition duration-300" />
                            </div>
                        )
                    ))}
                </div>
            </div>
        </section>
    )}

    <footer id="kontakt" class="bg-slate-900 text-gray-400 pt-20 pb-10 border-t border-slate-800">
        <div class="max-w-7xl mx-auto px-4 grid md:grid-cols-3 gap-12 mb-16">
            <div class="text-center md:text-left">
                <h4 class="text-white text-lg font-bold mb-6 uppercase tracking-wider">Kontaktujte nás</h4>
                <div class="space-y-4 text-sm md:text-base">
                    <p class="flex items-center justify-center md:justify-start gap-3"><span class="text-[#ad6cdb]">📍</span> <span>{settings.address}</span></p>
                    <p class="flex items-center justify-center md:justify-start gap-3"><span class="text-[#ad6cdb]">📞</span> <a href={`tel:${settings.phone}`} class="hover:text-white transition">{settings.phone}</a></p>
                    <p class="flex items-center justify-center md:justify-start gap-3"><span class="text-[#ad6cdb]">✉️</span> <a href={`mailto:${settings.email}`} class="hover:text-white transition">{settings.email}</a></p>
                    <div class="pt-6 flex justify-center md:justify-start gap-6">
                        {settings.facebookLink && <a href={settings.facebookLink} class="text-gray-400 hover:text-[#ad6cdb] transition transform hover:scale-110">Facebook</a>}
                        {settings.instagramLink && <a href={settings.instagramLink} class="text-gray-400 hover:text-[#ad6cdb] transition transform hover:scale-110">Instagram</a>}
                    </div>
                </div>
            </div>
            <div class="text-center md:text-left">
                <h4 class="text-white text-lg font-bold mb-6 uppercase tracking-wider">Otevírací doba</h4>
                <ul class="space-y-3 inline-block text-left w-full max-w-xs">
                    {settings.openingHours && settings.openingHours.map((slot) => (
                        <li class="flex justify-between border-b border-gray-800 pb-2 text-sm">
                            <span>{slot.day}</span>
                            <span class="text-white font-medium">{slot.time}</span>
                        </li>
                    ))}
                </ul>
            </div>
            <div class="text-center md:text-left">
                 <h4 class="text-white text-lg font-bold mb-6 uppercase tracking-wider">Tady nás najdete</h4>
                 <div class="h-48 rounded-xl overflow-hidden relative group">
                    {settings.footerImage ? (
                        <img src={settings.footerImage} class="w-full h-full object-cover group-hover:scale-105 transition duration-700" alt="Kde nás najdete" />
                    ) : (
                        <div class="w-full h-full bg-slate-800 flex items-center justify-center text-slate-600 text-sm">Nahrajte fotku v adminu</div>
                    )}
                </div>
            </div>
        </div>
        <div class="border-t border-slate-800 pt-8 text-center text-xs text-gray-600">
            <p>&copy; 2025 Rybízák Frýdek-Místek. Všechna práva vyhrazena.</p>
            {settings.companyInfo && <p class="mt-2 text-slate-700">{settings.companyInfo}</p>}
        </div>
    </footer>

    <!-- Employee profile modal -->
    <div id="empModal" class="fixed inset-0 z-[100] hidden">
        <div id="empModalOverlay" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
        <div class="relative z-10 flex items-end sm:items-center justify-center min-h-full p-0 sm:p-4">
            <div id="empModalCard" class="bg-white sm:rounded-2xl rounded-t-2xl shadow-2xl max-w-md w-full max-h-[92vh] overflow-y-auto relative transform transition-all duration-300 translate-y-4 sm:scale-95 opacity-0">
                <button id="empModalClose" class="absolute top-3 right-3 z-20 w-9 h-9 rounded-full bg-black/30 hover:bg-black/50 backdrop-blur-sm flex items-center justify-center text-white transition">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
                <div id="empModalBanner" class="w-full aspect-[4/3] overflow-hidden sm:rounded-t-2xl rounded-t-2xl bg-gray-100 relative"></div>
                <div id="empModalBody" class="px-6 pb-6">
                    <div id="empModalAvatarWrap" class="text-center -mt-12 relative z-10 mb-3">
                        <div class="w-24 h-24 rounded-full border-4 border-white shadow-lg mx-auto overflow-hidden bg-gray-100">
                            <img id="empModalAvatarImg" src="" alt="" class="w-full h-full object-cover" />
                        </div>
                    </div>
                    <div class="text-center pt-2">
                        <h3 id="empModalName" class="text-2xl font-bold text-[#45225e]"></h3>
                        <p id="empModalPozice" class="text-sm font-semibold text-[#ad6cdb] uppercase tracking-wider mt-1"></p>
                    </div>
                    <div id="empModalText" class="text-gray-600 text-sm leading-relaxed mt-4"></div>
                    <div id="empModalVino" class="hidden border-t border-gray-100 pt-4 mt-5">
                        <p class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-3">Oblíbené víno</p>
                        <a id="empModalVinoLink" href="#" target="_blank" rel="noopener" class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl hover:bg-gray-100 transition group">
                            <img id="empModalVinoImg" src="" alt="" class="w-14 h-14 object-contain rounded-lg bg-white shadow-sm flex-shrink-0" />
                            <span id="empModalVinoNazev" class="text-sm font-semibold text-gray-800 group-hover:text-[#45225e] transition"></span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/fslightbox/3.0.9/index.min.js"></script>

    <script id="empProfileData" type="application/json" set:html={profileDataJson}></script>

    <script is:inline>
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');

        btn.addEventListener('click', () => {
            menu.classList.toggle('hidden');
        });

        menu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
                menu.classList.add('hidden');
            });
        });

        (function() {
            var profiles = {};
            try { profiles = JSON.parse(document.getElementById('empProfileData').textContent || '{}'); } catch(e) {}

            var modal = document.getElementById('empModal');
            var overlay = document.getElementById('empModalOverlay');
            var card = document.getElementById('empModalCard');
            var closeBtn = document.getElementById('empModalClose');
            var banner = document.getElementById('empModalBanner');
            var avatarWrap = document.getElementById('empModalAvatarWrap');
            var avatarImg = document.getElementById('empModalAvatarImg');
            var body = document.getElementById('empModalBody');

            function openModal(email) {
                var p = profiles[email];
                if (!p) return;

                var hasBannerImg = !!p.img;
                var heroSrc = p.img || p.foto || '';

                banner.innerHTML = '';
                if (heroSrc) {
                    var isVideo = /\.(mp4|webm|mov)(\?|$)/i.test(heroSrc);
                    if (isVideo) {
                        banner.innerHTML = '<video src="' + heroSrc + '" autoplay muted loop playsinline class="w-full h-full object-cover" style="object-position:top"></video>';
                    } else {
                        var img = document.createElement('img');
                        img.src = heroSrc;
                        img.alt = p.name;
                        img.className = 'w-full h-full object-cover';
                        banner.appendChild(img);
                    }
                    banner.style.display = '';
                } else {
                    banner.style.display = 'none';
                }

                if (p.foto && hasBannerImg) {
                    avatarImg.src = p.foto;
                    avatarImg.alt = p.name;
                    avatarWrap.style.display = '';
                } else {
                    avatarWrap.style.display = 'none';
                    body.style.paddingTop = heroSrc ? '1.5rem' : '2rem';
                }
                if (p.foto && hasBannerImg) body.style.paddingTop = '';

                document.getElementById('empModalName').textContent = p.name;
                var poziceEl = document.getElementById('empModalPozice');
                poziceEl.textContent = p.pozice || '';
                poziceEl.style.display = p.pozice ? '' : 'none';

                var textEl = document.getElementById('empModalText');
                if (p.text) {
                    textEl.innerHTML = p.text;
                    textEl.style.display = '';
                } else {
                    textEl.style.display = 'none';
                }

                var vinoEl = document.getElementById('empModalVino');
                if (p.vino && p.vino.nazev) {
                    document.getElementById('empModalVinoImg').src = p.vino.obrazek || '';
                    document.getElementById('empModalVinoNazev').textContent = p.vino.nazev;
                    document.getElementById('empModalVinoLink').href = p.vino.url || '#';
                    vinoEl.classList.remove('hidden');
                } else {
                    vinoEl.classList.add('hidden');
                }

                modal.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
                requestAnimationFrame(function() {
                    requestAnimationFrame(function() {
                        card.style.opacity = '1';
                        card.style.transform = 'translateY(0) scale(1)';
                    });
                });
            }

            function closeModal() {
                card.style.opacity = '0';
                card.style.transform = 'translateY(1rem) scale(0.97)';
                setTimeout(function() {
                    modal.classList.add('hidden');
                    document.body.style.overflow = '';
                    card.style.transform = 'translateY(1rem) scale(0.95)';
                }, 250);
            }

            closeBtn.addEventListener('click', closeModal);
            overlay.addEventListener('click', closeModal);

            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
            });

            document.querySelectorAll('.emp-profile').forEach(function(el) {
                el.addEventListener('click', function() {
                    var email = el.getAttribute('data-email');
                    if (email) openModal(email);
                });
            });
        })();
    </script>

</body>
</html>
