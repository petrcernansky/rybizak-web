---
import { getEntry, getCollection } from 'astro:content';

// Vynutíme čerstvé načtení při každém vstupu
export const prerender = false;

const homepageData = await getEntry('homepage', 'data');
const settings = homepageData?.data || {};

// --- ROBUSTNÍ LOGIKA DATA (Funguje pro String i Date object) ---

// 1. Získáme dnešek v ČR jako text "2025-12-06"
const todayISO = new Date().toLocaleDateString('en-CA', { timeZone: 'Europe/Prague' });

// 2. Pomocná funkce, která bezpečně převede cokoliv na "YYYY-MM-DD"
const toIsoString = (input) => {
    if (!input) return null;
    // Převede vstup na Date objekt a z něj vytáhne ISO text
    return new Date(input).toISOString().split('T')[0];
};

const showBanner = (() => {
    // Pokud není text, nezobrazovat
    if (!settings.infoBannerText) return false;

    // Bezpečně převedeme vstupy z adminu na text
    const startISO = toIsoString(settings.infoBannerStart);
    const endISO = toIsoString(settings.infoBannerEnd);

    // Kontrola OD
    if (startISO) {
        // Porovnáváme: "2025-12-06" < "2025-12-02" ?
        if (todayISO < startISO) return false;
    }

    // Kontrola DO
    if (endISO) {
        // Porovnáváme: "2025-12-06" > "2025-12-13" ?
        if (todayISO > endISO) return false;
    }

    return true;
})();

const benefity = await getCollection('benefits');
let menuList = await getCollection('menus');
const plakaty = await getCollection('concerts');
const hasEvents = plakaty.some((event) => Boolean(event.data.poster));

menuList.sort((a, b) => (a.data.priority || 99) - (b.data.priority || 99));

const NC_BASE = 'https://app.rybizak.cloud';
const NC_HEADERS = {
    'Authorization': 'Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOjEsInJvbGVOYW1lIjoiYWRtaW4iLCJpYXQiOjE3NzA1ODkzMTIsImV4cCI6MzMzMjgxODkzMTJ9.29n7mNqn-JZ-mUvYdSSXaPC-xrg3XLH_gfA6UPz7vdA',
    'Content-Type': 'application/json',
};

let teamMembers: { name: string; photo: string; email: string }[] = [];
const employeeByEmail = new Map<string, { jmeno: string; foto: string }>();

try {
    const ncRes = await fetch(NC_BASE + '/api/zamestnanci:list?pageSize=500', { headers: NC_HEADERS });
    if (ncRes.ok) {
        const ncJson = await ncRes.json();
        const all: any[] = Array.isArray(ncJson.data) ? ncJson.data : [];

        for (const r of all) {
            const email = ((r.email || '') as string).trim().toLowerCase();
            if (email) employeeByEmail.set(email, { jmeno: (r.jmeno || '').trim(), foto: (r.foto || '').trim() });
        }

        teamMembers = all
            .filter((r) => {
                const soucasny = r.soucasny === true || r.soucasny === 'true' || r.soucasny === 1;
                const pnv = r['pracuje-na-vinarne'] === true || r['pracuje_na_vinarne'] === true || r.pracuje_na_vinarne === true;
                const v = r.vinarna || {};
                const isTester = !!v.tester && v.tester !== false;
                return soucasny && pnv && !isTester;
            })
            .map((r) => ({
                name: (r.jmeno || '').trim(),
                photo: (r.foto || '').trim(),
                email: ((r.email || '') as string).trim().toLowerCase(),
            }))
            .filter((r) => r.name);
    }
} catch {
    // silently fail
}

type ShiftPerson = { name: string; photo: string; pozice: string };
let onShiftNow: ShiftPerson[] = [];

function shiftMinutes(od: string, doo: string): number {
    const [oh, om] = od.split(':').map(Number);
    const [ch, cm] = doo.split(':').map(Number);
    let start = oh * 60 + (om || 0);
    let end = ch * 60 + (cm || 0);
    if (end <= start) end += 24 * 60;
    return end - start;
}

try {
    const czNow = new Date(new Date().toLocaleString('en-US', { timeZone: 'Europe/Prague' }));
    const rok = czNow.getFullYear();
    const mesic = czNow.getMonth() + 1;
    const den = czNow.getDate();
    const nowMinutes = czNow.getHours() * 60 + czNow.getMinutes();

    const smRes = await fetch(
        NC_BASE + '/api/vinarna-smeny:list?pageSize=1&filter[rok]=' + rok + '&filter[mesic]=' + mesic,
        { headers: NC_HEADERS },
    );
    if (smRes.ok) {
        const smJson = await smRes.json();
        const list: any[] = smJson.data || [];
        if (list.length > 0) {
            const rec = list[0];
            let smenyRaw: any = {};
            try { smenyRaw = typeof rec.smeny === 'string' ? JSON.parse(rec.smeny) : rec.smeny || {}; } catch { smenyRaw = {}; }

            const monthlyMinutes = new Map<string, number>();
            for (const [, dayVal] of Object.entries(smenyRaw)) {
                const day = dayVal as any;
                if (!day || day.zavreno || !Array.isArray(day.shifts)) continue;
                for (const shift of day.shifts) {
                    if (!shift?.od || !shift?.do) continue;
                    const dur = shiftMinutes(shift.od, shift.do);
                    for (const p of (shift.lide || [])) {
                        if (!p?.email) continue;
                        const em = (p.email as string).trim().toLowerCase();
                        monthlyMinutes.set(em, (monthlyMinutes.get(em) || 0) + dur);
                    }
                }
            }

            teamMembers.sort((a, b) => (monthlyMinutes.get(b.email) || 0) - (monthlyMinutes.get(a.email) || 0));

            const dayData = smenyRaw[String(den)];
            if (dayData && !dayData.zavreno && Array.isArray(dayData.shifts)) {
                const seen = new Set<string>();
                for (const shift of dayData.shifts) {
                    if (!shift || !shift.od || !shift.do) continue;
                    const [oh, om] = shift.od.split(':').map(Number);
                    const [ch, cm] = shift.do.split(':').map(Number);
                    const shiftStart = oh * 60 + (om || 0);
                    let shiftEnd = ch * 60 + (cm || 0);
                    if (shiftEnd <= shiftStart) shiftEnd += 24 * 60;

                    if (nowMinutes < shiftStart || nowMinutes >= shiftEnd) continue;

                    for (const p of (shift.lide || [])) {
                        if (!p || !p.email) continue;
                        const email = (p.email as string).trim().toLowerCase();
                        if (seen.has(email)) continue;
                        seen.add(email);

                        const emp = employeeByEmail.get(email);
                        const fullName = (emp?.jmeno || p.jmeno || '').trim();
                        const firstName = fullName.split(/\s+/)[0] || '';
                        if (!firstName) continue;

                        onShiftNow.push({
                            name: firstName,
                            photo: emp?.foto || '',
                            pozice: (p.pozice || '').trim(),
                        });
                    }
                }
            }
        }
    }
} catch {
    // silently fail
}
