---
import fallback from '../data/fm-web-public-fallback.json';
import { getFmBenefitIcon, isLegacyBenefitIconUrl } from '../data/fm-benefit-icons';

const FM_WEB_URL =
    import.meta.env.PUBLIC_FM_WEB_URL || 'https://web.rybizak.cloud/api/vinarna/fm-web/public';

type FmHomepage = {
    infoBannerText?: string;
    infoBannerStart?: string;
    infoBannerEnd?: string;
    logo?: string;
    heroHeadline?: string;
    heroSubheadline?: string;
    heroImage?: string;
    reservationLink?: string;
    aboutHeadline?: string;
    aboutText?: string;
    aboutImage?: string;
    address?: string;
    phone?: string;
    email?: string;
    companyInfo?: string;
    openingHours?: { day: string; time: string }[];
    facebookLink?: string;
    instagramLink?: string;
};

type FmWebPublic = {
    version?: number;
    updatedAt?: string | null;
    homepage: FmHomepage;
    benefits: { id?: string; title: string; iconKey?: string; icon?: string }[];
    menus: {
        id?: string;
        title: string;
        priority?: number;
        images?: string[];
        document?: string | null;
        /** WebP náhled 1. strany z CRM uploadu (Bunny CDN) */
        documentPreview?: string | null;
        documentPages?: number | null;
    }[];
    concerts: { id?: string; title: string; poster?: string }[];
};

const FM_ORIGIN = 'https://fm.rybizak.cz';
const FM_PREZ_MARK = '/vinarna-prezentace/';
const FM_PREZ_CDN_BASE = 'https://rybizak.b-cdn.net/vinarna-prezentace/';

/** Soubory z prezentace patří na Bunny CDN; špatný host (www.rybizak.cz, …) dává 404 a iframe stejně neprojde. */
function rewritePrezentaceUrlsToCdn(href: string): string {
    let t = String(href || '').trim();
    if (!t) return t;
    if (t.includes(FM_PREZ_MARK)) {
        t = t.replace(/^https?:\/\/www\.rybizak\.cz/i, 'https://rybizak.b-cdn.net');
        t = t.replace(/^https?:\/\/rybizak\.cz/i, 'https://rybizak.b-cdn.net');
    }
    if (!t.includes(FM_PREZ_MARK)) return t;
    try {
        const u = /^https?:\/\//i.test(t) ? new URL(t) : new URL(t.startsWith('/') ? t : `/${t}`, `${FM_ORIGIN}/`);
        if (u.hostname.toLowerCase().includes('b-cdn.net')) return u.href;
        const i = u.pathname.indexOf(FM_PREZ_MARK);
        if (i === -1) return t;
        const tail = u.pathname.slice(i + FM_PREZ_MARK.length).replace(/^\/+/, '');
        if (!tail) return t;
        return FM_PREZ_CDN_BASE.replace(/\/?$/, '/') + tail;
    } catch {
        return t;
    }
}

function absolutizeUrl(u: string | undefined | null): string {
    const t = String(u || '').trim();
    if (!t) return '';
    if (/^https?:\/\//i.test(t)) return rewritePrezentaceUrlsToCdn(t);
    if (t.startsWith('//')) return rewritePrezentaceUrlsToCdn(`https:${t}`);
    try {
        const path = t.startsWith('/') ? t : `/${t}`;
        return rewritePrezentaceUrlsToCdn(new URL(path, `${FM_ORIGIN}/`).href);
    } catch {
        return rewritePrezentaceUrlsToCdn(t);
    }
}

async function loadFmWebPublic(): Promise<FmWebPublic | null> {
    try {
        const res = await fetch(FM_WEB_URL, { headers: { Accept: 'application/json' } });
        if (!res.ok) return null;
        const data = (await res.json()) as FmWebPublic;
        if (!data || typeof data !== 'object' || !data.homepage) return null;
        return data;
    } catch {
        return null;
    }
}

const payload = (await loadFmWebPublic()) || (fallback as FmWebPublic);
const settings: FmHomepage = payload.homepage || {};

/** Krátká cache na Vercel CDN ve shodě s API (CRM změny do ~1–2 min na webu). */
Astro.response.headers.set(
    'Cache-Control',
    'public, s-maxage=60, stale-while-revalidate=300',
);

const toIsoString = (input: unknown) => {
    if (!input) return null;
    return new Date(String(input)).toISOString().split('T')[0];
};

const showBanner = Boolean(settings.infoBannerText);
const infoBannerStartISO = toIsoString(settings.infoBannerStart) || '';
const infoBannerEndISO = toIsoString(settings.infoBannerEnd) || '';

const benefity = Array.isArray(payload.benefits) ? payload.benefits : [];
const rawMenuList = Array.isArray(payload.menus) ? payload.menus : [];
const plakaty = Array.isArray(payload.concerts) ? payload.concerts.filter((e) => Boolean(e.poster)) : [];
const hasEvents = plakaty.length > 0;

const reservationHref = String(settings.reservationLink || '').trim();
const showReservation = Boolean(reservationHref);

type MenuCard = {
    slug: string;
    title: string;
    priority: number;
    images: string[];
    document: string | null;
    documentPreview: string | null;
    kind: 'images' | 'pdf';
    href: string;
    pageCount: number;
    pdfPages: number | null;
};

const slugifyTitle = (title: string) =>
    String(title || '')
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-|-$/g, '') || 'menu';

const getPageLabel = (count: number) => {
    if (count === 1) return '1 strana';
    if (count >= 2 && count <= 4) return `${count} strany`;
    return `${count} stran`;
};

const getPdfPageLabel = (n: number | null | undefined) => {
    if (n == null || n < 1) return 'PDF menu';
    return getPageLabel(n);
};

const menuList: MenuCard[] = rawMenuList
    .map((menu, idx) => {
        const imagesRaw = Array.isArray(menu.images) ? menu.images.filter(Boolean) : [];
        const images = imagesRaw.map((u) => absolutizeUrl(String(u)));
        const document = typeof menu.document === 'string' && menu.document ? absolutizeUrl(menu.document) : null;
        const kind = document ? 'pdf' : 'images';
        const slug = String(menu.id || '').trim() || slugifyTitle(menu.title) || `menu-${idx}`;
        const dp = menu.documentPages != null ? Number(menu.documentPages) : NaN;
        const pdfPages = kind === 'pdf' && !Number.isNaN(dp) && dp > 0 ? Math.round(dp) : null;
        const rawPrev =
            kind === 'pdf' && typeof menu.documentPreview === 'string' && menu.documentPreview.trim()
                ? menu.documentPreview.trim()
                : '';
        const documentPreview = rawPrev ? absolutizeUrl(rawPrev) : null;

        return {
            slug,
            title: menu.title,
            priority: menu.priority ?? 99,
            images,
            document,
            documentPreview,
            kind,
            href: document || images[0] || '#menu',
            pageCount: images.length,
            pdfPages,
        };
    })
    .filter((menu) => menu.pageCount > 0 || Boolean(menu.document))
    .sort((a, b) => a.priority - b.priority);

const defaultBenefitIcon = getFmBenefitIcon('sparkles');

const TEAM_SKELETON_COUNT = 8;
const REVIEW_SKELETON_COUNT = 3;

/** Souřadnice Rybízák – Frýdlantská 770 (OSM Nominatim) */
const venueMap = {
    lat: 49.6714113,
    lon: 18.3470138,
    /** Celá adresa pro Google Mapy a popisky */
    placeLabel: 'Rybízák, Frýdlantská 770, 738 01 Frýdek-Místek 1, Česko',
} as const;
/** Užší bbox = vyšší zoom v OSM embedu (≈ úroveň jedné ulice) */
const mapPadLon = 0.00085;
const mapPadLat = 0.00055;
const osmBbox = `${venueMap.lon - mapPadLon},${venueMap.lat - mapPadLat},${venueMap.lon + mapPadLon},${venueMap.lat + mapPadLat}`;
const osmEmbedUrl = `https://www.openstreetmap.org/export/embed.html?bbox=${encodeURIComponent(osmBbox)}&layer=mapnik`;
/** Karta místa (ne navigace) — oficiální Google Maps Place */
const googleMapsPlaceUrl =
    'https://www.google.com/maps/place/Ryb%C3%ADz%C3%A1k/@49.6714121,18.3444481,17z/data=!3m1!4b1!4m6!3m5!1s0x4713f6dfe06d1b41:0xa13c8372529713e0!8m2!3d49.6714087!4d18.347023!16s%2Fg%2F11b6_48s5r';
const footerBuildYear = new Date().getFullYear();
---

<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Rybízák Frýdek-Místek</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href="/fonts/billy/billy-bold.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/billy/billy-regular.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        @font-face {
            font-family: 'Billy Bold';
            src: url('/fonts/billy/billy-bold.ttf') format('truetype');
            font-weight: normal;
            font-style: normal;
            font-display: swap;
        }
        @font-face {
            font-family: 'Billy Regular';
            src: url('/fonts/billy/billy-regular.ttf') format('truetype');
            font-weight: normal;
            font-style: normal;
            font-display: swap;
        }
        .fm-font-display {
            font-family: 'Billy Bold', 'Inter', ui-sans-serif, system-ui, sans-serif;
            font-weight: normal;
        }
        .fm-font-heading {
            font-family: 'Billy Regular', 'Inter', ui-sans-serif, system-ui, sans-serif;
            font-weight: normal;
        }
        .team-scroll { -ms-overflow-style: none; scrollbar-width: none; }
        .team-scroll::-webkit-scrollbar { display: none; }
        .review-scroll { -ms-overflow-style: none; scrollbar-width: none; }
        .review-scroll::-webkit-scrollbar { display: none; }
        .emp-profile:hover img { box-shadow: 0 0 0 3px rgba(69,34,94,0.3); }
        .is-loading::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.72), transparent);
            transform: translateX(-100%);
            animation: shimmer 1.3s infinite;
        }
        #empModalCard { transition: opacity 0.25s ease, transform 0.25s ease; }
        #empModalBanner.emp-modal-banner-video { background: linear-gradient(180deg, #2f1844 0%, #140a1e 100%); }
        #empModalText p { margin-bottom: 0.75em; }
        #empModalText p:last-child { margin-bottom: 0; }
        #empModalText {
            display: -webkit-box;
            -webkit-box-orient: vertical;
            -webkit-line-clamp: 8;
            overflow: hidden;
        }
        @media (min-width: 640px) {
            #empModalText { -webkit-line-clamp: 10; }
        }
        @keyframes shimmer {
            100% { transform: translateX(100%); }
        }
        /* Patička: spolehlivá barva mimo Tailwind + mapa bez rozbití gridu */
        #kontakt.site-footer {
            background-color: #45225e;
            color: rgba(255, 255, 255, 0.82);
        }
        #kontakt.site-footer .site-footer-inner {
            min-width: 0;
        }
        #kontakt.site-footer .site-footer-map-shell {
            width: 100%;
            max-width: 100%;
            min-width: 0;
            isolation: isolate;
        }
        #kontakt.site-footer .site-footer-map-shell iframe {
            max-width: 100%;
        }
        /* PDF menu — modal prohlížeč */
        #fmPdfModal .fm-pdf-modal-panel {
            box-shadow: 0 25px 80px -12px rgba(69, 34, 94, 0.35), 0 12px 32px -8px rgba(0, 0, 0, 0.2);
        }
        #fmPdfPagesInner canvas {
            image-rendering: auto;
        }
    </style>
</head>
<body class="bg-gray-50 text-slate-800 font-['Inter'] antialiased flex flex-col min-h-screen">

    {showBanner && (
        <div
            class="hidden bg-black text-yellow-300 text-center py-3 px-4 font-bold text-sm relative z-[60]"
            data-banner
            data-banner-start={infoBannerStartISO}
            data-banner-end={infoBannerEndISO}
        >
            {settings.infoBannerText}
        </div>
    )}

    <nav class="sticky top-0 w-full z-50 bg-white/95 backdrop-blur-md shadow-sm border-b border-gray-100 transition-all duration-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <div class="flex-shrink-0 flex items-center">
                    <a href="#" class="block hover:opacity-80 transition">
                        {settings.logo ? (
                            <img class="h-10 w-auto md:h-12" src={absolutizeUrl(settings.logo)} alt="Rybízák Logo" width="140" height="48" decoding="async" />
                        ) : (
                            <span class="fm-font-display text-2xl text-[#45225e]">RYBÍZÁK</span>
                        )}
                    </a>
                </div>

                <div class="hidden md:flex space-x-8 items-center">
                    <a href="#menu" class="text-sm font-semibold text-gray-600 hover:text-[#45225e] uppercase tracking-wider transition">Nabídka</a>
                    {hasEvents && (
                        <a href="#akce" class="text-sm font-semibold text-gray-600 hover:text-[#45225e] uppercase tracking-wider transition">Akce</a>
                    )}
                    <a href="https://www.rybizak.cz" class="text-sm font-semibold text-gray-600 hover:text-[#45225e] uppercase tracking-wider transition">E-shop</a>
                    <a href="https://fm.rybizak.cz/zakaznicka-karticka" class="text-sm font-semibold text-gray-600 hover:text-[#45225e] uppercase tracking-wider transition">Zákaznická kartička</a>
                    <a href="https://fm.rybizak.cz/chytry-kviz" class="text-sm font-semibold text-gray-600 hover:text-[#45225e] uppercase tracking-wider transition">Chytrý kvíz</a>
                    <a href="#kontakt" class="text-sm font-semibold text-gray-600 hover:text-[#45225e] uppercase tracking-wider transition">Kontakt</a>
                    {showReservation && (
                        <a href={reservationHref} class="bg-[#45225e] text-white px-6 py-2 rounded-full font-bold text-sm hover:bg-[#351a4a] transition shadow-lg shadow-purple-900/20 transform hover:-translate-y-0.5">
                            REZERVACE
                        </a>
                    )}
                </div>

                <div class="md:hidden flex items-center">
                    <button id="mobile-menu-btn" class="text-gray-800 hover:text-[#45225e] focus:outline-none p-2 border border-gray-200 rounded-md">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 w-full bg-white border-b border-gray-100 shadow-xl flex flex-col">
            <div class="px-4 py-6 space-y-4 text-center">
                <a href="#menu" class="block text-lg font-bold text-gray-800 hover:text-[#45225e]">NABÍDKA</a>
                {hasEvents && (
                    <a href="#akce" class="block text-lg font-bold text-gray-800 hover:text-[#45225e]">AKCE</a>
                )}
                <a href="https://www.rybizak.cz" class="block text-lg font-bold text-gray-800 hover:text-[#45225e]">E-SHOP</a>
                <a href="https://fm.rybizak.cz/zakaznicka-karticka" class="block text-lg font-bold text-gray-800 hover:text-[#45225e]">ZÁKAZNICKÁ KARTIČKA</a>
                <a href="https://fm.rybizak.cz/chytry-kviz" class="block text-lg font-bold text-gray-800 hover:text-[#45225e]">CHYTRÝ KVÍZ</a>
                <a href="#kontakt" class="block text-lg font-bold text-gray-800 hover:text-[#45225e]">KONTAKT</a>
                {showReservation && (
                    <a href={reservationHref} class="inline-block bg-[#45225e] text-white py-3 px-12 rounded-full font-bold shadow-md mt-2">
                        REZERVACE
                    </a>
                )}
            </div>
        </div>
    </nav>

    <header class="relative h-[85vh] flex items-center justify-center">
        {settings.heroImage && (
            <div class="absolute inset-0 z-0">
                <img src={absolutizeUrl(settings.heroImage)} alt="Úvod" class="w-full h-full object-cover" fetchpriority="high" decoding="async" />
                <div class="absolute inset-0 bg-gradient-to-r from-slate-900/80 via-slate-900/40 to-transparent"></div>
            </div>
        )}
        <div class="relative z-10 max-w-7xl mx-auto px-4 w-full">
            <div class="text-left text-white space-y-4 max-w-2xl">
                <h1 class="fm-font-display text-4xl md:text-6xl leading-tight drop-shadow-xl">
                    {settings.heroHeadline}
                </h1>
                <p class="text-lg md:text-xl text-gray-100 font-light max-w-lg leading-relaxed">
                    {settings.heroSubheadline}
                </p>
                <div class="pt-6">
                    {showReservation && (
                        <a href={reservationHref} class="inline-block bg-[#45225e] hover:bg-[#5a2d7a] text-white text-base px-8 py-3 rounded-full font-bold transition transform hover:scale-105 shadow-xl uppercase tracking-wide">
                            Rezervovat stůl
                        </a>
                    )}
                </div>
            </div>
        </div>
    </header>

    {benefity.length > 0 && (
        <section class="relative z-20 -mt-10 mx-3 border-b border-gray-100 bg-white py-10 shadow-lg sm:mx-4 md:mx-auto md:max-w-5xl md:rounded-xl">
            <div class="mx-auto flex w-full max-w-7xl flex-wrap justify-center gap-x-4 gap-y-8 px-3 sm:px-4">
                {benefity.map((item) => {
                    const iconDef = getFmBenefitIcon(item.iconKey);
                    const legacySrc = isLegacyBenefitIconUrl(item.icon) ? absolutizeUrl(item.icon) : null;
                    return (
                        <div class="box-border flex w-[calc((100%-2rem)/3)] max-w-[11rem] shrink-0 grow-0 flex-col items-center text-center md:w-[calc((100%-5rem)/6)] md:max-w-[10rem] lg:max-w-[11rem]">
                            <div class="mb-3 flex h-14 w-14 shrink-0 items-center justify-center text-[#45225e]">
                                {iconDef ? (
                                    <svg
                                        class="h-11 w-11"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        stroke-width="1.5"
                                        aria-hidden="true"
                                    >
                                        {iconDef.paths.map((d) => (
                                            <path stroke-linecap="round" stroke-linejoin="round" d={d} />
                                        ))}
                                    </svg>
                                ) : legacySrc ? (
                                    <img
                                        src={legacySrc}
                                        alt=""
                                        class="h-11 w-11 object-contain opacity-90"
                                        loading="lazy"
                                        decoding="async"
                                    />
                                ) : defaultBenefitIcon ? (
                                    <svg
                                        class="h-11 w-11"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        stroke-width="1.5"
                                        aria-hidden="true"
                                    >
                                        {defaultBenefitIcon.paths.map((d) => (
                                            <path stroke-linecap="round" stroke-linejoin="round" d={d} />
                                        ))}
                                    </svg>
                                ) : null}
                            </div>
                            <h3 class="fm-font-heading text-[11px] leading-tight text-[#45225e] sm:text-xs">{item.title}</h3>
                        </div>
                    );
                })}
            </div>
        </section>
    )}

    <section class="py-20 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4">
            <div class="flex flex-col md:flex-row items-center gap-12 md:gap-20">
                <div class="md:w-1/2 relative">
                    {settings.aboutImage && (
                        <>
                            <div class="absolute inset-0 bg-[#45225e] rounded-3xl transform rotate-3 translate-x-2 translate-y-2 opacity-20"></div>
                            <img src={absolutizeUrl(settings.aboutImage)} alt="O nás" class="relative rounded-3xl shadow-xl w-full object-cover aspect-[4/3]" loading="lazy" decoding="async" />
                        </>
                    )}
                </div>
                <div class="md:w-1/2 space-y-6 text-center md:text-left">
                    <h2 class="fm-font-heading text-3xl md:text-4xl text-[#45225e]">{settings.aboutHeadline}</h2>
                    <p class="text-base text-gray-600 leading-relaxed whitespace-pre-line">
                        {settings.aboutText}
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="py-12 bg-white border-t border-gray-100" data-team-section hidden>
            <h2 class="fm-font-heading text-3xl text-[#45225e] text-center mb-8">Náš tým</h2>
            <div class="relative">
                <div class="pointer-events-none absolute left-0 top-0 bottom-0 w-8 bg-gradient-to-r from-white to-transparent z-10"></div>
                <div class="pointer-events-none absolute right-0 top-0 bottom-0 w-8 bg-gradient-to-l from-white to-transparent z-10"></div>
                <div class="team-scroll overflow-x-auto" data-team-track>
                    <div class="flex gap-8 md:gap-10 px-10 py-2 w-max mx-auto" data-team-list>
                        {Array.from({ length: TEAM_SKELETON_COUNT }).map(() => (
                            <div class="flex flex-col items-center group flex-shrink-0">
                                <div class="w-20 h-20 md:w-24 md:h-24 mb-2 relative overflow-hidden rounded-full bg-gray-200 is-loading"></div>
                                <div class="relative h-4 w-20 overflow-hidden rounded-full bg-gray-200 is-loading"></div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <section class="pt-6 pb-12 bg-white" data-shift-section hidden>
            <div class="max-w-7xl mx-auto px-4 text-center">
                <div class="inline-flex items-center gap-2.5 bg-green-50 border border-green-200 rounded-full px-5 py-2 mb-6">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                    </span>
                    <span class="text-sm font-bold text-green-800 uppercase tracking-wider">Právě se o Vás stará</span>
                </div>
                <div class="flex flex-wrap justify-center gap-8" data-shift-list></div>
            </div>
        </section>

   {menuList.length > 0 && (
        <section id="menu" class="bg-gray-50 py-16 sm:py-20 md:py-24">
            <div class="mx-auto max-w-7xl px-3 text-center sm:px-4">
                <h2 class="fm-font-heading mb-10 text-3xl text-[#45225e] md:mb-14 md:text-4xl">Naše nabídka</h2>

                <div
                    class:list={[
                        'mx-auto grid items-stretch gap-5 sm:gap-6 lg:gap-8',
                        menuList.length === 1 && 'max-w-md grid-cols-1',
                        menuList.length === 2 && 'max-w-4xl grid-cols-1 sm:grid-cols-2',
                        menuList.length >= 3 && 'max-w-7xl grid-cols-1 sm:grid-cols-2 xl:grid-cols-3',
                    ]}
                >
                    {menuList.map((menu) => (
                        <article class="group flex h-full flex-col rounded-3xl border border-gray-100 bg-white p-4 text-left shadow-lg transition duration-300 hover:-translate-y-0.5 hover:shadow-xl sm:rounded-[2rem] sm:p-5">
                            <div class="mb-4 flex items-start justify-between gap-3 sm:mb-5">
                                <div class="min-w-0 flex-1">
                                    {menu.kind === 'pdf' && (
                                        <p class="mb-1 text-[10px] font-bold uppercase tracking-[0.28em] text-[#ad6cdb] sm:text-xs sm:tracking-[0.35em]">
                                            Digitální menu
                                        </p>
                                    )}
                                    <h3 class="fm-font-heading text-lg leading-tight text-gray-900 sm:text-xl xl:text-2xl">
                                        {menu.title}
                                    </h3>
                                </div>
                                <span class="shrink-0 rounded-full bg-[#45225e]/10 px-2.5 py-1.5 text-[10px] font-bold uppercase leading-none tracking-wide text-[#45225e] sm:px-3 sm:py-2 sm:text-[11px] sm:tracking-[0.2em]">
                                    {menu.kind === 'pdf' ? getPdfPageLabel(menu.pdfPages) : getPageLabel(menu.pageCount)}
                                </span>
                            </div>

                            {menu.kind === 'pdf' ? (
                                <div class="flex min-h-0 flex-1 flex-col gap-3">
                                    <button
                                        type="button"
                                        class="group/pdf relative block w-full overflow-hidden rounded-2xl border border-[#45225e]/12 bg-gradient-to-br from-[#faf6ff] via-white to-slate-100 text-left shadow-inner transition hover:border-[#45225e]/25 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#45225e] focus-visible:ring-offset-2"
                                        data-fm-pdf-open
                                        data-pdf-url={menu.href}
                                        data-pdf-title={menu.title}
                                        aria-label={`Prohlédnout menu: ${menu.title}`}
                                    >
                                        <div class="relative aspect-[4/5] w-full sm:aspect-[3/4]">
                                            {menu.documentPreview ? (
                                                <>
                                                    <img
                                                        src={menu.documentPreview}
                                                        alt={`Náhled menu ${menu.title}`}
                                                        class="h-full w-full object-cover object-top transition duration-500 group-hover/pdf:scale-[1.02]"
                                                        loading="lazy"
                                                        decoding="async"
                                                    />
                                                    <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[#2f1844]/75 via-[#45225e]/10 to-transparent" />
                                                    <div class="pointer-events-none absolute inset-0 flex items-center justify-center opacity-0 transition duration-300 group-hover/pdf:opacity-100">
                                                        <span class="rounded-full bg-white/95 px-5 py-2.5 text-sm font-bold text-[#45225e] shadow-lg backdrop-blur-sm">
                                                            Prohlédnout menu
                                                        </span>
                                                    </div>
                                                </>
                                            ) : (
                                                <div class="flex h-full w-full flex-col items-center justify-center gap-3 px-5 py-8 text-center">
                                                    <span class="text-4xl text-[#45225e]/90 sm:text-5xl" aria-hidden="true">
                                                        📄
                                                    </span>
                                                    <p class="max-w-xs text-xs leading-relaxed text-slate-600 sm:text-sm">
                                                        Po opětovném nahrání PDF v administraci se zde zobrazí náhled první strany. Menu si můžete prohlédnout v přehledném okně.
                                                    </p>
                                                </div>
                                            )}
                                        </div>
                                    </button>
                                    <div class="mt-auto">
                                        <button
                                            type="button"
                                            class="inline-flex w-full items-center justify-center rounded-full bg-[#45225e] px-4 py-3 text-sm font-bold text-white transition hover:bg-[#5b2d7a]"
                                            data-fm-pdf-open
                                            data-pdf-url={menu.href}
                                            data-pdf-title={menu.title}
                                        >
                                            Prohlédnout menu
                                        </button>
                                    </div>
                                </div>
                            ) : (
                                <div class="flex h-full flex-col">
                                    <div class="relative w-full aspect-[4/5]">
                                        <a data-fslightbox={`gallery-${menu.slug}`} href={menu.href} class="block relative w-full h-full">
                                            {menu.pageCount > 1 && (
                                                <div class="absolute inset-0 bg-white rounded-[1.75rem] shadow-md border border-gray-200 transform translate-x-3 translate-y-3 rotate-3 transition duration-300 group-hover:translate-x-4 group-hover:translate-y-4 group-hover:rotate-6 z-0"></div>
                                            )}
                                            {menu.pageCount > 2 && (
                                                <div class="absolute inset-0 bg-white rounded-[1.75rem] shadow-md border border-gray-200 transform -translate-x-2 translate-y-2 -rotate-2 transition duration-300 group-hover:-translate-x-3 group-hover:translate-y-3 group-hover:-rotate-4 z-0"></div>
                                            )}
                                            <div class="relative z-10 w-full h-full bg-white rounded-[1.75rem] shadow-xl overflow-hidden border border-gray-100 transition duration-300 transform group-hover:-translate-y-1">
                                                <img src={menu.images[0]} alt={menu.title} class="w-full h-full object-cover" loading="lazy" decoding="async" />
                                                <div class="absolute inset-0 bg-gradient-to-t from-black/35 via-black/0 to-black/0"></div>
                                                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition duration-300 flex items-center justify-center">
                                                    <span class="opacity-0 group-hover:opacity-100 bg-[#45225e] text-white px-4 py-2 rounded-full font-bold shadow-lg transform translate-y-4 group-hover:translate-y-0 transition duration-300">
                                                        Prohlédnout
                                                    </span>
                                                </div>
                                            </div>
                                        </a>
                                        {menu.pageCount > 1 && (
                                            <div class="absolute -top-3 -right-3 z-20 bg-[#45225e] text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg border-2 border-white">
                                                {getPageLabel(menu.pageCount)}
                                            </div>
                                        )}
                                        {menu.images.slice(1).map((img) => (
                                            <a data-fslightbox={`gallery-${menu.slug}`} href={img} class="hidden"></a>
                                        ))}
                                    </div>
                                </div>
                            )}
                        </article>
                    ))}
                </div>
            </div>
        </section>
    )}

