                        >
                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                            </svg>
                        </button>
                    </div>
                </div>
                <div
                    class="min-h-0 flex-1 overflow-y-auto overscroll-contain bg-gradient-to-b from-slate-100/90 via-white to-slate-50/80"
                    data-fm-pdf-scroll
                >
                    <div class="flex justify-center p-3 pb-8 sm:p-6 sm:pb-12">
                        <div
                            id="fmPdfPagesInner"
                            class="flex w-full max-w-full flex-col items-center gap-4 sm:gap-6"
                            data-fm-pdf-pages-inner
                        >
                        </div>
                    </div>
                </div>
        </div>
    </div>

    <script is:inline>
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');

        btn.addEventListener('click', () => {
            menu.classList.toggle('hidden');
        });

        menu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
                menu.classList.add('hidden');
            });
        });

        (function() {
            var modal = document.getElementById('empModal');
            var card = document.getElementById('empModalCard');
            var closeBtn = document.getElementById('empModalClose');
            var banner = document.getElementById('empModalBanner');
            var avatarWrap = document.getElementById('empModalAvatarWrap');
            var avatarImg = document.getElementById('empModalAvatarImg');
            var teamSection = document.querySelector('[data-team-section]');
            var teamList = document.querySelector('[data-team-list]');
            var shiftSection = document.querySelector('[data-shift-section]');
            var shiftList = document.querySelector('[data-shift-list]');
            var reviewSection = document.querySelector('[data-reviews-section]');
            var reviewTrack = document.querySelector('[data-review-list]');
            var reviewControls = document.querySelector('[data-review-carousel-controls]');
            var prevButton = document.querySelector('[data-review-carousel-prev]');
            var nextButton = document.querySelector('[data-review-carousel-next]');
            var profiles = {};
            var lightboxRequested = false;

            function toggleBanner() {
                var bannerEl = document.querySelector('[data-banner]');
                if (!bannerEl) return;

                var now = new Date().toLocaleDateString('en-CA', { timeZone: 'Europe/Prague' });
                var start = bannerEl.getAttribute('data-banner-start');
                var end = bannerEl.getAttribute('data-banner-end');
                var visible = true;

                if (start && now < start) visible = false;
                if (end && now > end) visible = false;

                bannerEl.classList.toggle('hidden', !visible);
            }

            function escapeHtml(value) {
                return String(value || '').replace(/[&<>"']/g, function(char) {
                    return ({
                        '&': '&amp;',
                        '<': '&lt;',
                        '>': '&gt;',
                        '"': '&quot;',
                        "'": '&#39;'
                    })[char];
                });
            }

            function ensureLightbox() {
                if (lightboxRequested || !document.querySelector('[data-fslightbox]')) return;
                lightboxRequested = true;

                var script = document.createElement('script');
                script.src = 'https://cdnjs.cloudflare.com/ajax/libs/fslightbox/3.0.9/index.min.js';
                script.defer = true;
                document.body.appendChild(script);
            }

            function renderPerson(person, variant) {
                var isShift = variant === 'shift';
                var hasProfile = Boolean(person.email && profiles[person.email]);
                var wrapperClass = 'flex flex-col items-center group flex-shrink-0' + (hasProfile ? ' cursor-pointer emp-profile' : '');
                var photoBoxClass = 'w-20 h-20 md:w-24 md:h-24 mb-2';
                var photoHtml = person.photo
                    ? '<img src="' + escapeHtml(person.photo) + '" alt="' + escapeHtml(person.name) + '" class="relative w-full h-full rounded-full object-cover border-[3px] border-white shadow-md group-hover:scale-105 transition duration-300" loading="lazy" decoding="async" />'
                    : '<div class="w-full h-full bg-gray-200 rounded-full flex items-center justify-center text-2xl">🍷</div>';
                var positionHtml = isShift && person.pozice
                    ? '<span class="text-[11px] font-bold uppercase tracking-wider text-green-700/70 mt-1">' + escapeHtml(person.pozice) + '</span>'
                    : '';

                return '<div class="' + wrapperClass + '" data-email="' + escapeHtml(person.email || '') + '">' +
                    '<div class="' + photoBoxClass + ' relative">' + photoHtml + '</div>' +
                    '<span class="text-sm font-semibold text-gray-800">' + escapeHtml(person.name) + '</span>' +
                    positionHtml +
                '</div>';
            }

            var REVIEW_COLLAPSE_LENGTH = 160;
            var reviewVisibilityObserver = null;

            function truncateReviewComment(comment) {
                var normalizedComment = String(comment || '').trim();
                if (normalizedComment.length <= REVIEW_COLLAPSE_LENGTH) {
                    return {
                        full: normalizedComment,
                        preview: normalizedComment,
                        isLong: false
                    };
                }

                var preview = normalizedComment.slice(0, REVIEW_COLLAPSE_LENGTH);
                var lastSpace = preview.lastIndexOf(' ');
                if (lastSpace > REVIEW_COLLAPSE_LENGTH * 0.65) {
                    preview = preview.slice(0, lastSpace);
                }

                return {
                    full: normalizedComment,
                    preview: preview.replace(/[\s.,;:!?-]+$/u, '') + '…',
                    isLong: true
                };
            }

            function renderReview(review, useCarousel) {
                var comment = truncateReviewComment(review.comment);
                return '<article data-review-card class="relative h-full rounded-[2rem] border border-[#45225e]/10 bg-gradient-to-br from-[#fffaf5] via-white to-[#faf6ff] p-7 shadow-[0_8px_32px_-4px_rgba(69,34,94,0.09),0_2px_8px_-2px_rgba(69,34,94,0.06)]' + (useCarousel ? ' snap-start' : '') + '">' +
                    '<div class="absolute right-0 top-0 h-28 w-28 rounded-full bg-[#ad6cdb]/10 blur-3xl"></div>' +
                    '<div class="relative z-10 flex h-full flex-col">' +
                        '<div class="flex items-center justify-between gap-4">' +
                            '<div>' +
                                '<div class="text-lg font-bold text-[#45225e]">' + escapeHtml(review.author) + '</div>' +
                                '<span class="inline-flex items-center rounded-full bg-white/90 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.28em] text-slate-500 shadow-sm">Ověřené hodnocení</span>' +
                            '</div>' +
                            (review.publishedAt ? '<span class="text-sm font-medium text-slate-500">' + escapeHtml(review.publishedAt) + '</span>' : '') +
                        '</div>' +
                        '<div class="mt-6 flex items-center gap-3">' +
                            '<span class="select-none text-2xl font-black leading-none tracking-[0.2em] text-transparent bg-clip-text" style="background-image: linear-gradient(90deg, #f59e0b ' + (Number(review.starValue || 0) * 20) + '%, #e5e7eb ' + (Number(review.starValue || 0) * 20) + '%);" aria-hidden="true">★★★★★</span>' +
                            '<span class="text-sm font-bold text-amber-600">' + escapeHtml(review.starLabel) + ' / 5</span>' +
                        '</div>' +
                        '<div class="mt-6 flex-1">' +
                            '<p class="text-base leading-8 text-slate-700" data-review-comment data-review-collapsed="' + (comment.isLong ? 'true' : 'false') + '"' + (comment.isLong ? ' data-review-preview="' + escapeHtml(comment.preview) + '" data-review-full="' + escapeHtml(comment.full) + '"' : '') + '>"' + escapeHtml(comment.isLong ? comment.preview : comment.full) + '</p>' +
                        '</div>' +
                        (comment.isLong
                            ? '<button type="button" class="mt-4 inline-flex self-start rounded-full border border-[#45225e]/10 bg-white/90 px-4 py-2 text-sm font-semibold text-[#45225e] shadow-sm transition hover:bg-[#faf6ff]" data-review-toggle aria-expanded="false">Více</button>'
                            : '') +
                    '</div>' +
                '</article>';
            }

            function collapseReviewCard(card) {
                if (!card) return;
                var comment = card.querySelector('[data-review-comment]');
                var toggle = card.querySelector('[data-review-toggle]');
                if (!comment || !toggle || comment.dataset.reviewCollapsed === 'true') return;

                comment.textContent = comment.dataset.reviewPreview || '';
                comment.dataset.reviewCollapsed = 'true';
                toggle.textContent = 'Více';
                toggle.setAttribute('aria-expanded', 'false');
            }

            function toggleReviewCard(card) {
                if (!card) return;
                var comment = card.querySelector('[data-review-comment]');
                var toggle = card.querySelector('[data-review-toggle]');
                if (!comment || !toggle) return;

                var isCollapsed = comment.dataset.reviewCollapsed !== 'false';
                comment.textContent = isCollapsed ? (comment.dataset.reviewFull || '') : (comment.dataset.reviewPreview || '');
                comment.dataset.reviewCollapsed = isCollapsed ? 'false' : 'true';
                toggle.textContent = isCollapsed ? 'Méně' : 'Více';
                toggle.setAttribute('aria-expanded', isCollapsed ? 'true' : 'false');
            }

            function bindReviewToggles() {
                if (!reviewTrack || reviewTrack.dataset.reviewToggleBound === 'true') return;
                reviewTrack.dataset.reviewToggleBound = 'true';

                reviewTrack.addEventListener('click', function(event) {
                    var toggle = event.target && event.target.closest('[data-review-toggle]');
                    if (!toggle) return;

                    var card = toggle.closest('[data-review-card]');
                    toggleReviewCard(card);
                });
            }

            function observeReviewVisibility() {
                if (!reviewTrack) return;
                if (reviewVisibilityObserver) {
                    reviewVisibilityObserver.disconnect();
                    reviewVisibilityObserver = null;
                }

                if (reviewTrack.dataset.reviewCarousel !== 'true' || typeof IntersectionObserver === 'undefined') return;

                reviewVisibilityObserver = new IntersectionObserver(function(entries) {
                    entries.forEach(function(entry) {
                        if (entry.isIntersecting && entry.intersectionRatio >= 0.6) return;
                        collapseReviewCard(entry.target);
                    });
                }, {
                    root: reviewTrack,
                    threshold: [0.6]
                });

                reviewTrack.querySelectorAll('[data-review-card]').forEach(function(card) {
                    reviewVisibilityObserver.observe(card);
                });
            }

            function bindProfileTriggers() {
                document.querySelectorAll('.emp-profile').forEach(function(el) {
                    if (el.dataset.profileBound === 'true') return;
                    el.dataset.profileBound = 'true';
                    el.addEventListener('click', function() {
                        var email = el.getAttribute('data-email');
                        if (email) openModal(email);
                    });
                });
            }

            function getReviewScrollAmount() {
                if (!reviewTrack) return 0;
                var firstCard = reviewTrack.querySelector('[data-review-card]');
                if (!firstCard) return reviewTrack.clientWidth;

                var styles = window.getComputedStyle(reviewTrack);
                var gap = parseFloat(styles.columnGap || styles.gap || '0') || 0;
                var cardWidth = firstCard.getBoundingClientRect().width;
                var visibleCards = window.innerWidth >= 1280 ? 3 : window.innerWidth >= 768 ? 2 : 1;

                return (cardWidth + gap) * visibleCards;
            }

            function updateReviewButtons() {
                if (!reviewTrack || !prevButton || !nextButton) return;
                var maxScrollLeft = Math.max(0, reviewTrack.scrollWidth - reviewTrack.clientWidth - 4);
                prevButton.disabled = reviewTrack.scrollLeft <= 4;
                nextButton.disabled = reviewTrack.scrollLeft >= maxScrollLeft;
            }

            function setupReviewCarousel(useCarousel) {
                if (!reviewTrack || !reviewControls) return;

                reviewTrack.dataset.reviewCarousel = useCarousel ? 'true' : 'false';
                reviewTrack.className = useCarousel
                    ? 'review-scroll grid grid-flow-col auto-cols-[calc(100%-1rem)] gap-6 overflow-x-auto py-2 pb-4 snap-x snap-mandatory md:auto-cols-[calc((100%-1.5rem)/2)] xl:auto-cols-[calc((100%-3rem)/3)]'
                    : 'grid gap-6 lg:grid-cols-3';

                reviewControls.classList.toggle('hidden', !useCarousel);
                reviewControls.classList.toggle('flex', useCarousel);
                updateReviewButtons();
            }

            async function loadHomepageData() {
                try {
                    var response = await fetch('/api/homepage-dynamic');
                    if (!response.ok) return;

                    var data = await response.json();
                    profiles = data.profiles || {};

                    if (teamSection && teamList && Array.isArray(data.teamMembers) && data.teamMembers.length) {
                        teamList.innerHTML = data.teamMembers.map(function(person) {
                            return renderPerson(person, 'team');
                        }).join('');
                        teamSection.hidden = false;
                    }

                    if (shiftSection && shiftList && Array.isArray(data.onShiftNow) && data.onShiftNow.length) {
                        shiftList.innerHTML = data.onShiftNow.map(function(person) {
                            return renderPerson(person, 'shift');
                        }).join('');
                        shiftSection.hidden = false;
                    }

                    if (reviewSection && reviewTrack && Array.isArray(data.reviews) && data.reviews.length) {
                        var useCarousel = data.reviews.length > 3;
                        reviewTrack.innerHTML = data.reviews.map(function(review) {
                            return renderReview(review, useCarousel);
                        }).join('');
                        reviewSection.hidden = false;
                        bindReviewToggles();
                        setupReviewCarousel(useCarousel);
                        observeReviewVisibility();
                        requestAnimationFrame(function() {
                            requestAnimationFrame(function() {
                                updateReviewButtons();
                                if (typeof window.__syncReviewCarouselButtons === 'function') {
                                    window.__syncReviewCarouselButtons();
                                }
                            });
                        });
                    }

                    bindProfileTriggers();
                    ensureLightbox();
                } catch (error) {
                    console.error('Homepage dynamic data failed', error);
                }
            }

            toggleBanner();
            ensureLightbox();

            function openModal(email) {
                var p = profiles[email];
                if (!p) return;

                var heroSrc = p.img || p.foto || '';

                banner.innerHTML = '';
                banner.classList.remove('emp-modal-banner-video');
                if (heroSrc) {
                    var isVideo = /\.(mp4|webm|mov)(\?|$)/i.test(heroSrc);
                    if (isVideo) {
                        banner.classList.add('emp-modal-banner-video');
                        var video = document.createElement('video');
                        video.src = heroSrc;
                        video.autoplay = true;
                        video.muted = true;
                        video.loop = true;
                        video.playsInline = true;
                        video.className = 'h-full w-full object-contain';
                        banner.appendChild(video);
                    } else {
                        var img = document.createElement('img');
                        img.src = heroSrc;
                        img.alt = p.name;
                        img.className = 'w-full h-full object-cover';
                        banner.appendChild(img);
                    }
                    banner.style.display = '';
                } else {
                    banner.style.display = 'none';
                }

                if (p.foto) {
                    avatarImg.src = p.foto;
                    avatarImg.alt = p.name;
                    avatarWrap.style.display = '';
                } else {
                    avatarWrap.style.display = 'none';
                }

                document.getElementById('empModalName').textContent = p.name;
                var poziceEl = document.getElementById('empModalPozice');
                poziceEl.textContent = p.pozice || '';
                poziceEl.style.display = p.pozice ? '' : 'none';

                var textEl = document.getElementById('empModalText');
                if (p.text) {
                    textEl.innerHTML = p.text;
                    textEl.style.display = '';
                } else {
                    textEl.style.display = 'none';
                }

                var vinoEl = document.getElementById('empModalVino');
                if (p.vino && p.vino.nazev) {
                    document.getElementById('empModalVinoImg').src = p.vino.obrazek || '';
                    document.getElementById('empModalVinoNazev').textContent = p.vino.nazev;
                    document.getElementById('empModalVinoLink').href = p.vino.url || '#';
                    vinoEl.classList.remove('hidden');
                } else {
                    vinoEl.classList.add('hidden');
                }

                modal.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
                requestAnimationFrame(function() {
                    requestAnimationFrame(function() {
                        card.style.opacity = '1';
                        card.style.transform = 'translateY(0) scale(1)';
                    });
                });
            }

            function closeModal() {
                card.style.opacity = '0';
                card.style.transform = 'translateY(1rem) scale(0.97)';
                setTimeout(function() {
                    modal.classList.add('hidden');
                    document.body.style.overflow = '';
                    card.style.transform = 'translateY(1rem) scale(0.95)';
                }, 250);
            }

            closeBtn.addEventListener('click', closeModal);
            modal.addEventListener('click', function(e) {
                if (!modal.classList.contains('hidden') && !card.contains(e.target)) closeModal();
            });

            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
            });
            loadHomepageData();
        })();

        (function() {
            var track = document.querySelector('[data-review-list]');
            if (!track) return;

            var prevButton = document.querySelector('[data-review-carousel-prev]');
            var nextButton = document.querySelector('[data-review-carousel-next]');

            function updateButtons() {
                if (!prevButton || !nextButton) return;

                var maxScrollLeft = Math.max(0, track.scrollWidth - track.clientWidth - 4);
                prevButton.disabled = track.scrollLeft <= 4;
                nextButton.disabled = track.scrollLeft >= maxScrollLeft;
            }

            if (prevButton) {
                prevButton.addEventListener('click', function() {
                    track.scrollBy({ left: -((window.getReviewScrollAmount && window.getReviewScrollAmount()) || track.clientWidth), behavior: 'smooth' });
                });
            }

            if (nextButton) {
                nextButton.addEventListener('click', function() {
                    track.scrollBy({ left: (window.getReviewScrollAmount && window.getReviewScrollAmount()) || track.clientWidth, behavior: 'smooth' });
                });
            }

            track.addEventListener('scroll', updateButtons, { passive: true });
            window.addEventListener('resize', updateButtons);
            window.__syncReviewCarouselButtons = updateButtons;
            if (typeof ResizeObserver !== 'undefined') {
                try {
                    new ResizeObserver(updateButtons).observe(track);
                } catch (e) {}
            }
            if (document.fonts && document.fonts.ready) {
                document.fonts.ready.then(function() {
                    updateButtons();
                });
            }
            window.getReviewScrollAmount = function() {
                var firstCard = track.querySelector('[data-review-card]');
                if (!firstCard) return track.clientWidth;
                var styles = window.getComputedStyle(track);
                var gap = parseFloat(styles.columnGap || styles.gap || '0') || 0;
                var cardWidth = firstCard.getBoundingClientRect().width;
                var visibleCards = window.innerWidth >= 1280 ? 3 : window.innerWidth >= 768 ? 2 : 1;
                return (cardWidth + gap) * visibleCards;
            };
            updateButtons();
        })();
    </script>

    <script is:inline>
        (function () {
            var y = document.getElementById('footer-year');
            if (y) {
                var yr = String(new Date().getFullYear());
                y.textContent = yr;
                y.setAttribute('datetime', yr);
            }
        })();
    </script>

    <script is:inline>
        (function () {
            var modal = document.getElementById('fmPdfModal');
            if (!modal) return;
            var panel = modal.querySelector('[data-fm-pdf-panel]');
            var inner = document.getElementById('fmPdfPagesInner');
            var titleEl = modal.querySelector('[data-fm-pdf-title]');
            var statusEl = modal.querySelector('[data-fm-pdf-status]');
            var scrollEl = modal.querySelector('[data-fm-pdf-scroll]');
            var closeBtn = modal.querySelector('[data-fm-pdf-close]');
            var zoomIn = modal.querySelector('[data-fm-pdf-zoom-in]');
            var zoomOut = modal.querySelector('[data-fm-pdf-zoom-out]');
            var pdfjsMod = null;
            var currentPdf = null;
            /** Násobič zoomu — překreslení canvasů (ne CSS scale), ostré i při přiblížení. */
            var pdfZoomMul = 1;
            var rerenderTimer = null;
            var BASE_CSS_SCALE = 1.18;

            function showModal() {
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                document.body.style.overflow = 'hidden';
            }

            function hideModal() {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
                document.body.style.overflow = '';
                if (rerenderTimer) {
                    clearTimeout(rerenderTimer);
                    rerenderTimer = null;
                }
                if (inner) inner.innerHTML = '';
                if (currentPdf && currentPdf.destroy) {
                    try {
                        currentPdf.destroy();
                    } catch (e) {}
                    currentPdf = null;
                }
            }

            function loadPdfJs() {
                if (pdfjsMod) return Promise.resolve(pdfjsMod);
                return import('https://cdn.jsdelivr.net/npm/pdfjs-dist@4.10.38/legacy/build/pdf.mjs').then(function (m) {
                    m.GlobalWorkerOptions.workerSrc =
                        'https://cdn.jsdelivr.net/npm/pdfjs-dist@4.10.38/legacy/build/pdf.worker.min.mjs';
                    pdfjsMod = m;
                    return m;
                });
            }

            function escapeAttr(s) {
                return String(s || '')
                    .replace(/&/g, '&amp;')
                    .replace(/"/g, '&quot;')
                    .replace(/</g, '&lt;');
            }

            function pdfDataFetchUrl(publicUrl) {
                try {
                    var u = new URL(publicUrl, window.location.origin);
                    if (u.pathname.toLowerCase().indexOf('/vinarna-prezentace/') === -1) {
                        return publicUrl;
                    }
                    if (u.origin === window.location.origin) {
                        return publicUrl;
                    }
                    var h = u.hostname.toLowerCase();
                    if (
                        h === 'rybizak.b-cdn.net' ||
                        h === 'www.rybizak.cz' ||
                        h === 'rybizak.cz'
                    ) {
                        return (
                            window.location.origin +
                            '/api/fm-pdf-proxy?u=' +
                            encodeURIComponent(u.href)
                        );
                    }
                } catch (e) {}
                return publicUrl;
            }

            function effectiveRenderScale() {
                var dpr = Math.min(typeof window.devicePixelRatio === 'number' ? window.devicePixelRatio : 1, 2.5);
                return BASE_CSS_SCALE * pdfZoomMul * dpr;
            }

            function renderAllPagesIntoInner(pdf) {
                if (!inner || !statusEl || !pdf) return Promise.resolve();
                inner.innerHTML = '';
                var total = pdf.numPages;
                var scale = effectiveRenderScale();
                var chain = Promise.resolve();
                var maxCanvasSide = 8192;
                for (var p = 1; p <= total; p++) {
                    (function (pageNum) {
                        chain = chain.then(function () {
                            statusEl.textContent = 'Vykresluji stránku ' + pageNum + ' / ' + total;
                            return pdf.getPage(pageNum).then(function (page) {
                                var vp = page.getViewport({ scale: scale });
                                if (vp.width > maxCanvasSide || vp.height > maxCanvasSide) {
                                    var f = Math.min(maxCanvasSide / vp.width, maxCanvasSide / vp.height, 1);
                                    vp = page.getViewport({ scale: scale * f });
                                }
                                var canvas = document.createElement('canvas');
                                var ctx = canvas.getContext('2d');
                                canvas.width = Math.floor(vp.width);
                                canvas.height = Math.floor(vp.height);
                                canvas.className = 'h-auto max-w-full rounded-xl bg-white shadow-md sm:rounded-2xl sm:shadow-lg';
                                return page.render({ canvasContext: ctx, viewport: vp }).promise.then(function () {
                                    inner.appendChild(canvas);
                                });
                            });
                        });
                    })(p);
                }
                return chain.then(function () {
                    statusEl.textContent = total === 1 ? '1 strana' : total + ' stran';
                    if (scrollEl) scrollEl.scrollTop = 0;
                });
            }

            function scheduleRerenderPages() {
                if (!currentPdf) return;
                if (rerenderTimer) clearTimeout(rerenderTimer);
                rerenderTimer = setTimeout(function () {
                    rerenderTimer = null;
                    statusEl.textContent = 'Upravuji přiblížení…';
                    renderAllPagesIntoInner(currentPdf).catch(function () {});
                }, 140);
            }

            function openPdfViewer(url, title) {
                if (!inner || !statusEl || !titleEl) return;
                showModal();
                titleEl.textContent = title || 'Menu';
                var fetchUrl = pdfDataFetchUrl(url);
                inner.innerHTML = '<p class="py-16 text-center text-slate-500">Načítám menu…</p>';
                statusEl.textContent = 'Načítám…';
                pdfZoomMul = 1;

                loadPdfJs()
                    .then(function () {
                        return fetch(fetchUrl, { credentials: 'same-origin', cache: 'default' });
                    })
                    .then(function (res) {
                        if (!res.ok) throw new Error('HTTP ' + res.status);
                        return res.arrayBuffer();
                    })
                    .then(function (buf) {
                        return loadPdfJs().then(function (pdfjs) {
                            var loadingTask = pdfjs.getDocument({
                                data: new Uint8Array(buf),
                                useSystemFonts: true,
                                isEvalSupported: false,
                            });
                            return loadingTask.promise;
                        });
                    })
                    .then(function (pdf) {
                        currentPdf = pdf;
                        return renderAllPagesIntoInner(pdf);
                    })
                    .catch(function () {
                        statusEl.textContent = 'Záložní zobrazení';
                        var iframeSrc = escapeAttr(fetchUrl) + '#view=FitH';
                        inner.innerHTML =
                            '<div class="mx-auto w-full max-w-2xl rounded-2xl border border-slate-200 bg-white/95 p-4 shadow-sm sm:p-6">' +
                            '<p class="mb-4 text-center text-sm leading-relaxed text-slate-600">Menu se nepodařilo vykreslit jako obrázky. Zobrazujeme vestavěné zobrazení PDF.</p>' +
                            '<iframe title="PDF menu" src="' +
                            iframeSrc +
                            '" class="h-[min(72dvh,640px)] w-full rounded-xl border border-slate-200 bg-slate-100"></iframe>' +
                            '<p class="mt-4 text-center"><a class="inline-flex rounded-full bg-[#45225e] px-5 py-2.5 text-sm font-bold text-white transition hover:bg-[#5b2d7a]" href="' +
                            escapeAttr(url) +
                            '" target="_blank" rel="noopener noreferrer">Otevřít v novém okně</a></p></div>';
                        if (scrollEl) scrollEl.scrollTop = 0;
                    });
            }

            modal.addEventListener('click', function (e) {
                if (!panel || panel.contains(e.target)) return;
                hideModal();
            });

            document.addEventListener('click', function (ev) {
                var t = ev.target;
                if (!t || !t.closest) return;
                var opener = t.closest('[data-fm-pdf-open]');
                if (!opener) return;
                ev.preventDefault();
                var pdfUrl = opener.getAttribute('data-pdf-url');
                if (!pdfUrl) return;
                openPdfViewer(pdfUrl, opener.getAttribute('data-pdf-title') || '');
            });

            if (closeBtn) {
                closeBtn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    hideModal();
                });
            }
            if (zoomIn) {
                zoomIn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    pdfZoomMul = Math.min(2.85, pdfZoomMul + 0.16);
                    scheduleRerenderPages();
                });
            }
            if (zoomOut) {
                zoomOut.addEventListener('click', function (e) {
                    e.stopPropagation();
                    pdfZoomMul = Math.max(0.55, pdfZoomMul - 0.16);
                    scheduleRerenderPages();
                });
            }

            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) hideModal();
            });
        })();
    </script>

</body>
</html>
