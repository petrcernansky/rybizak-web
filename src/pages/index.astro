---
import { getEntry, getCollection } from 'astro:content';

const homepageData = await getEntry('homepage', 'data');
const settings = homepageData?.data || {};

const toIsoString = (input) => {
    if (!input) return null;
    return new Date(input).toISOString().split('T')[0];
};

const showBanner = Boolean(settings.infoBannerText);
const infoBannerStartISO = toIsoString(settings.infoBannerStart) || '';
const infoBannerEndISO = toIsoString(settings.infoBannerEnd) || '';

const benefity = await getCollection('benefits');
const rawMenuList = await getCollection('menus');
const plakaty = await getCollection('concerts');
const hasEvents = plakaty.some((event) => Boolean(event.data.poster));

type MenuCard = {
    slug: string;
    title: string;
    priority: number;
    images: string[];
    document: string | null;
    kind: 'images' | 'pdf';
    href: string;
    pageCount: number;
};

const getPageLabel = (count: number) => {
    if (count === 1) return '1 strana';
    if (count >= 2 && count <= 4) return `${count} strany`;
    return `${count} stran`;
};

const menuList: MenuCard[] = rawMenuList
    .map((menu) => {
        const images = Array.isArray(menu.data.images) ? menu.data.images.filter(Boolean) : [];
        const document = typeof menu.data.document === 'string' && menu.data.document ? menu.data.document : null;
        const kind = document ? 'pdf' : 'images';

        return {
            slug: menu.slug,
            title: menu.data.title,
            priority: menu.data.priority || 99,
            images,
            document,
            kind,
            href: document || images[0] || '#menu',
            pageCount: images.length,
        };
    })
    .filter((menu) => menu.pageCount > 0 || Boolean(menu.document))
    .sort((a, b) => a.priority - b.priority);

const TEAM_SKELETON_COUNT = 8;
const REVIEW_SKELETON_COUNT = 3;
---

<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Rybízák Frýdek-Místek</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        .team-scroll { -ms-overflow-style: none; scrollbar-width: none; }
        .team-scroll::-webkit-scrollbar { display: none; }
        .review-scroll { -ms-overflow-style: none; scrollbar-width: none; }
        .review-scroll::-webkit-scrollbar { display: none; }
        .emp-profile:hover img { box-shadow: 0 0 0 3px rgba(69,34,94,0.3); }
        .is-loading::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.72), transparent);
            transform: translateX(-100%);
            animation: shimmer 1.3s infinite;
        }
        #empModalCard { transition: opacity 0.25s ease, transform 0.25s ease; }
        #empModalBanner.emp-modal-banner-video { background: linear-gradient(180deg, #2f1844 0%, #140a1e 100%); }
        #empModalText p { margin-bottom: 0.75em; }
        #empModalText p:last-child { margin-bottom: 0; }
        #empModalText {
            display: -webkit-box;
            -webkit-box-orient: vertical;
            -webkit-line-clamp: 8;
            overflow: hidden;
        }
        @media (min-width: 640px) {
            #empModalText { -webkit-line-clamp: 10; }
        }
        @keyframes shimmer {
            100% { transform: translateX(100%); }
        }
    </style>
</head>
<body class="bg-gray-50 text-slate-800 font-['Inter'] antialiased flex flex-col min-h-screen">

    {showBanner && (
        <div
            class="hidden bg-black text-yellow-300 text-center py-3 px-4 font-bold text-sm relative z-[60]"
            data-banner
            data-banner-start={infoBannerStartISO}
            data-banner-end={infoBannerEndISO}
        >
            {settings.infoBannerText}
        </div>
    )}

    <nav class="sticky top-0 w-full z-50 bg-white/95 backdrop-blur-md shadow-sm border-b border-gray-100 transition-all duration-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <div class="flex-shrink-0 flex items-center">
                    <a href="#" class="block hover:opacity-80 transition">
                        {settings.logo ? (
                            <img class="h-10 w-auto md:h-12" src={settings.logo} alt="Rybízák Logo" width="140" height="48" decoding="async" />
                        ) : (
                            <span class="text-2xl font-bold text-[#45225e]">RYBÍZÁK</span>
                        )}
                    </a>
                </div>

                <div class="hidden md:flex space-x-8 items-center">
                    <a href="#menu" class="text-sm font-semibold text-gray-600 hover:text-[#45225e] uppercase tracking-wider transition">Nabídka</a>
                    {hasEvents && (
                        <a href="#akce" class="text-sm font-semibold text-gray-600 hover:text-[#45225e] uppercase tracking-wider transition">Akce</a>
                    )}
                    <a href="https://www.rybizak.cz" class="text-sm font-semibold text-gray-600 hover:text-[#45225e] uppercase tracking-wider transition">E-shop</a>
                    <a href="https://fm.rybizak.cz/zakaznicka-karticka" class="text-sm font-semibold text-gray-600 hover:text-[#45225e] uppercase tracking-wider transition">Zákaznická kartička</a>
                    <a href="https://fm.rybizak.cz/chytry-kviz" class="text-sm font-semibold text-gray-600 hover:text-[#45225e] uppercase tracking-wider transition">Chytrý kvíz</a>
                    <a href="#kontakt" class="text-sm font-semibold text-gray-600 hover:text-[#45225e] uppercase tracking-wider transition">Kontakt</a>
                    {settings.reservationLink && (
                        <a href="https://fm.rybizak.cz/rezervace" class="bg-[#45225e] text-white px-6 py-2 rounded-full font-bold text-sm hover:bg-[#351a4a] transition shadow-lg shadow-purple-900/20 transform hover:-translate-y-0.5">
                            REZERVACE
                        </a>
                    )}
                </div>

                <div class="md:hidden flex items-center">
                    <button id="mobile-menu-btn" class="text-gray-800 hover:text-[#45225e] focus:outline-none p-2 border border-gray-200 rounded-md">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 w-full bg-white border-b border-gray-100 shadow-xl flex flex-col">
            <div class="px-4 py-6 space-y-4 text-center">
                <a href="#menu" class="block text-lg font-bold text-gray-800 hover:text-[#45225e]">NABÍDKA</a>
                {hasEvents && (
                    <a href="#akce" class="block text-lg font-bold text-gray-800 hover:text-[#45225e]">AKCE</a>
                )}
                <a href="https://www.rybizak.cz" class="block text-lg font-bold text-gray-800 hover:text-[#45225e]">E-SHOP</a>
                <a href="https://fm.rybizak.cz/zakaznicka-karticka" class="block text-lg font-bold text-gray-800 hover:text-[#45225e]">ZÁKAZNICKÁ KARTIČKA</a>
                <a href="https://fm.rybizak.cz/chytry-kviz" class="block text-lg font-bold text-gray-800 hover:text-[#45225e]">CHYTRÝ KVÍZ</a>
                <a href="#kontakt" class="block text-lg font-bold text-gray-800 hover:text-[#45225e]">KONTAKT</a>
                {settings.reservationLink && (
                    <a href="https://fm.rybizak.cz/rezervace" class="inline-block bg-[#45225e] text-white py-3 px-12 rounded-full font-bold shadow-md mt-2">
                        REZERVACE
                    </a>
                )}
            </div>
        </div>
    </nav>

    <header class="relative h-[85vh] flex items-center justify-center">
        {settings.heroImage && (
            <div class="absolute inset-0 z-0">
                <img src={settings.heroImage} alt="Úvod" class="w-full h-full object-cover" fetchpriority="high" decoding="async" />
                <div class="absolute inset-0 bg-gradient-to-r from-slate-900/80 via-slate-900/40 to-transparent"></div>
            </div>
        )}
        <div class="relative z-10 max-w-7xl mx-auto px-4 w-full">
            <div class="text-left text-white space-y-4 max-w-2xl">
                <h1 class="text-4xl md:text-6xl font-bold leading-tight drop-shadow-xl">
                    {settings.heroHeadline}
                </h1>
                <p class="text-lg md:text-xl text-gray-100 font-light max-w-lg leading-relaxed">
                    {settings.heroSubheadline}
                </p>
                <div class="pt-6">
                    {settings.reservationLink && (
                        <a href={settings.reservationLink} class="inline-block bg-[#45225e] hover:bg-[#5a2d7a] text-white text-base px-8 py-3 rounded-full font-bold transition transform hover:scale-105 shadow-xl uppercase tracking-wide">
                            Rezervovat stůl
                        </a>
                    )}
                </div>
            </div>
        </div>
    </header>

    {benefity.length > 0 && (
        <section class="py-8 bg-white border-b border-gray-100 relative z-20 -mt-10 mx-4 md:mx-auto max-w-6xl rounded-xl shadow-lg">
            <div class="grid grid-cols-3 md:grid-flow-col md:auto-cols-fr gap-4 px-2 md:px-8 text-center items-start justify-center">
                {benefity.map((item) => (
                    <div class="flex flex-col items-center justify-start group h-full px-1">
                        {item.data.icon && (
                            <img src={item.data.icon} alt={item.data.title} class="h-8 w-8 md:h-12 md:w-12 mb-2 md:mb-3 object-contain opacity-80 group-hover:opacity-100 transition" decoding="async" />
                        )}
                        <h3 class="text-[11px] md:text-xs font-bold text-[#45225e] leading-tight normal-case break-words w-full">
                            {item.data.title}
                        </h3>
                    </div>
                ))}
            </div>
        </section>
    )}

    <section class="py-20 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4">
            <div class="flex flex-col md:flex-row items-center gap-12 md:gap-20">
                <div class="md:w-1/2 relative">
                    {settings.aboutImage && (
                        <>
                            <div class="absolute inset-0 bg-[#45225e] rounded-3xl transform rotate-3 translate-x-2 translate-y-2 opacity-20"></div>
                            <img src={settings.aboutImage} alt="O nás" class="relative rounded-3xl shadow-xl w-full object-cover aspect-[4/3]" loading="lazy" decoding="async" />
                        </>
                    )}
                </div>
                <div class="md:w-1/2 space-y-6 text-center md:text-left">
                    <h2 class="text-3xl md:text-4xl font-bold text-[#45225e]">{settings.aboutHeadline}</h2>
                    <p class="text-base text-gray-600 leading-relaxed whitespace-pre-line">
                        {settings.aboutText}
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="py-12 bg-white border-t border-gray-100" data-team-section hidden>
            <h2 class="text-3xl font-bold text-[#45225e] text-center mb-8">Náš tým</h2>
            <div class="relative">
                <div class="pointer-events-none absolute left-0 top-0 bottom-0 w-8 bg-gradient-to-r from-white to-transparent z-10"></div>
                <div class="pointer-events-none absolute right-0 top-0 bottom-0 w-8 bg-gradient-to-l from-white to-transparent z-10"></div>
                <div class="team-scroll overflow-x-auto" data-team-track>
                    <div class="flex gap-8 md:gap-10 px-10 py-2 w-max mx-auto" data-team-list>
                        {Array.from({ length: TEAM_SKELETON_COUNT }).map(() => (
                            <div class="flex flex-col items-center group flex-shrink-0">
                                <div class="w-20 h-20 md:w-24 md:h-24 mb-2 relative overflow-hidden rounded-full bg-gray-200 is-loading"></div>
                                <div class="relative h-4 w-20 overflow-hidden rounded-full bg-gray-200 is-loading"></div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <section class="pt-6 pb-12 bg-white" data-shift-section hidden>
            <div class="max-w-7xl mx-auto px-4 text-center">
                <div class="inline-flex items-center gap-2.5 bg-green-50 border border-green-200 rounded-full px-5 py-2 mb-6">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                    </span>
                    <span class="text-sm font-bold text-green-800 uppercase tracking-wider">Právě na směně</span>
                </div>
                <div class="flex flex-wrap justify-center gap-8" data-shift-list></div>
            </div>
        </section>

   {menuList.length > 0 && (
        <section id="menu" class="py-24 bg-gray-50">
            <div class="max-w-7xl mx-auto px-4 text-center">
                <h2 class="text-3xl md:text-4xl font-bold text-[#45225e] mb-16">Naše nabídka</h2>

                <div class="grid gap-6 lg:gap-8 sm:grid-cols-2 xl:grid-cols-3 max-w-7xl mx-auto items-stretch">
                    {menuList.map((menu) => (
                        <article class="group flex h-full flex-col rounded-[2rem] border border-white/70 bg-white p-4 sm:p-5 text-left shadow-[0_24px_80px_rgba(15,23,42,0.08)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_28px_90px_rgba(69,34,94,0.16)]">
                            <div class="mb-6 flex items-start justify-between gap-4">
                                <div>
                                    {menu.kind === 'pdf' && (
                                        <p class="text-xs font-semibold uppercase tracking-[0.35em] text-[#ad6cdb] mb-2">
                                            PDF nabídka
                                        </p>
                                    )}
                                    <h3 class="text-xl xl:text-2xl font-bold text-gray-900 leading-tight">
                                        {menu.title}
                                    </h3>
                                </div>
                                <span class="shrink-0 rounded-full bg-[#45225e]/8 px-3 py-2 text-[11px] font-bold uppercase tracking-[0.22em] text-[#45225e]">
                                    {menu.kind === 'pdf' ? 'PDF' : getPageLabel(menu.pageCount)}
                                </span>
                            </div>

                            {menu.kind === 'pdf' ? (
                                <div class="flex h-full flex-col">
                                    <a href={menu.href} target="_blank" rel="noreferrer" class="block relative w-full aspect-[4/5] overflow-hidden rounded-[1.75rem] border border-[#45225e]/10 bg-gradient-to-br from-[#faf6ff] via-white to-[#efe5ff] p-6 sm:p-8">
                                        <div class="absolute inset-x-0 top-0 h-28 bg-gradient-to-b from-[#45225e]/10 to-transparent"></div>
                                        <div class="relative z-10 flex h-full flex-col justify-between">
                                            <div class="flex items-center justify-between gap-4">
                                                <div class="rounded-2xl bg-[#45225e] px-4 py-3 text-left text-white shadow-lg">
                                                    <div class="text-[11px] uppercase tracking-[0.35em] text-white/70">Dokument</div>
                                                    <div class="text-xl font-bold">PDF</div>
                                                </div>
                                                <div class="rounded-full border border-[#45225e]/15 bg-white/80 px-4 py-2 text-xs font-semibold uppercase tracking-[0.3em] text-[#45225e]">
                                                    Otevřít
                                                </div>
                                            </div>

                                            <div class="mx-auto w-full max-w-[16rem] rounded-[1.5rem] border border-white/80 bg-white/95 p-5 shadow-[0_20px_60px_rgba(69,34,94,0.12)]">
                                                <div class="mb-4 flex items-center justify-between">
                                                    <div class="h-3 w-16 rounded-full bg-[#45225e]/15"></div>
                                                    <div class="h-3 w-10 rounded-full bg-[#ad6cdb]/20"></div>
                                                </div>
                                                <div class="space-y-3">
                                                    <div class="h-3 rounded-full bg-slate-200"></div>
                                                    <div class="h-3 w-11/12 rounded-full bg-slate-200"></div>
                                                    <div class="h-3 w-4/5 rounded-full bg-slate-200"></div>
                                                    <div class="h-20 rounded-[1.25rem] bg-gradient-to-br from-[#45225e]/10 via-[#ad6cdb]/15 to-[#45225e]/5"></div>
                                                    <div class="h-3 w-10/12 rounded-full bg-slate-200"></div>
                                                    <div class="h-3 w-2/3 rounded-full bg-slate-200"></div>
                                                </div>
                                            </div>

                                            <div class="text-sm text-slate-600 leading-relaxed">
                                                Vícestránkové PDF otevřete jedním kliknutím v novém okně. Na mobilu funguje stejně spolehlivě jako na desktopu.
                                            </div>
                                        </div>
                                    </a>

                                    <div class="mt-5 flex flex-col sm:flex-row gap-3">
                                        <a href={menu.href} target="_blank" rel="noreferrer" class="inline-flex flex-1 items-center justify-center rounded-full bg-[#45225e] px-5 py-3 text-sm font-bold text-white transition hover:bg-[#5b2d7a]">
                                            Otevřít PDF
                                        </a>
                                        <a href={menu.href} download class="inline-flex flex-1 items-center justify-center rounded-full border border-[#45225e]/15 px-5 py-3 text-sm font-bold text-[#45225e] transition hover:border-[#45225e]/30 hover:bg-[#45225e]/5">
                                            Stáhnout
                                        </a>
                                    </div>
                                </div>
                            ) : (
                                <div class="flex h-full flex-col">
                                    <div class="relative w-full aspect-[4/5]">
                                        <a data-fslightbox={`gallery-${menu.slug}`} href={menu.href} class="block relative w-full h-full">
                                            {menu.pageCount > 1 && (
                                                <div class="absolute inset-0 bg-white rounded-[1.75rem] shadow-md border border-gray-200 transform translate-x-3 translate-y-3 rotate-3 transition duration-300 group-hover:translate-x-4 group-hover:translate-y-4 group-hover:rotate-6 z-0"></div>
                                            )}
                                            {menu.pageCount > 2 && (
                                                <div class="absolute inset-0 bg-white rounded-[1.75rem] shadow-md border border-gray-200 transform -translate-x-2 translate-y-2 -rotate-2 transition duration-300 group-hover:-translate-x-3 group-hover:translate-y-3 group-hover:-rotate-4 z-0"></div>
                                            )}
                                            <div class="relative z-10 w-full h-full bg-white rounded-[1.75rem] shadow-xl overflow-hidden border border-gray-100 transition duration-300 transform group-hover:-translate-y-1">
                                                <img src={menu.images[0]} alt={menu.title} class="w-full h-full object-cover" loading="lazy" decoding="async" />
                                                <div class="absolute inset-0 bg-gradient-to-t from-black/35 via-black/0 to-black/0"></div>
                                                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition duration-300 flex items-center justify-center">
                                                    <span class="opacity-0 group-hover:opacity-100 bg-[#45225e] text-white px-4 py-2 rounded-full font-bold shadow-lg transform translate-y-4 group-hover:translate-y-0 transition duration-300">
                                                        Prohlédnout
                                                    </span>
                                                </div>
                                            </div>
                                        </a>
                                        {menu.pageCount > 1 && (
                                            <div class="absolute -top-3 -right-3 z-20 bg-[#45225e] text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg border-2 border-white">
                                                {getPageLabel(menu.pageCount)}
                                            </div>
                                        )}
                                        {menu.images.slice(1).map((img) => (
                                            <a data-fslightbox={`gallery-${menu.slug}`} href={img} class="hidden"></a>
                                        ))}
                                    </div>
                                </div>
                            )}
                        </article>
                    ))}
                </div>
            </div>
        </section>
    )}

    <section id="recenze" class="py-12 md:py-16 bg-white" data-reviews-section hidden>
            <div class="max-w-7xl mx-auto px-4">
                <div class="mb-3 md:mb-4">
                    <div class="text-center">
                        <span class="inline-flex items-center rounded-full border border-[#45225e]/10 bg-[#faf6ff] px-4 py-2 text-xs font-bold uppercase tracking-[0.35em] text-[#7a49a3]">
                            Nejnovější recenze
                        </span>
                    </div>
                    <div class="mt-3 md:mt-4 flex flex-wrap items-center justify-between gap-x-3 gap-y-2">
                        <h2 class="min-w-0 flex-1 text-left text-2xl font-bold leading-tight text-[#45225e] sm:text-3xl md:text-4xl md:leading-tight">
                            Co o nás říkají hosté
                        </h2>
                        <div class="hidden shrink-0 items-center gap-2" data-review-carousel-controls>
                            <button
                                type="button"
                                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-[#45225e]/10 bg-white text-[#45225e] shadow-[0_2px_12px_rgba(69,34,94,0.08)] transition hover:-translate-y-0.5 hover:bg-[#faf6ff] disabled:cursor-not-allowed disabled:opacity-40 disabled:hover:translate-y-0 md:h-11 md:w-11"
                                data-review-carousel-prev
                                aria-label="Zobrazit předchozí recenze"
                            >
                                <span aria-hidden="true" class="text-lg leading-none md:text-xl">←</span>
                            </button>
                            <button
                                type="button"
                                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-[#45225e]/10 bg-white text-[#45225e] shadow-[0_2px_12px_rgba(69,34,94,0.08)] transition hover:-translate-y-0.5 hover:bg-[#faf6ff] disabled:cursor-not-allowed disabled:opacity-40 disabled:hover:translate-y-0 md:h-11 md:w-11"
                                data-review-carousel-next
                                aria-label="Zobrazit další recenze"
                            >
                                <span aria-hidden="true" class="text-lg leading-none md:text-xl">→</span>
                            </button>
                        </div>
                    </div>
                </div>

                <div
                    id="guest-reviews-track"
                    data-review-carousel="false"
                    data-review-list
                    class="grid gap-6 lg:grid-cols-3"
                >
                    {Array.from({ length: REVIEW_SKELETON_COUNT }).map(() => (
                        <article class="relative h-full overflow-hidden rounded-[2rem] border border-[#45225e]/10 bg-gradient-to-br from-[#fffaf5] via-white to-[#faf6ff] p-7 shadow-[0_8px_32px_-4px_rgba(69,34,94,0.09),0_2px_8px_-2px_rgba(69,34,94,0.06)] is-loading">
                            <div class="relative z-10 flex h-full flex-col">
                                <div class="flex items-center justify-between gap-4">
                                    <div class="space-y-3">
                                        <div class="h-5 w-32 rounded-full bg-white/90"></div>
                                        <div class="h-7 w-28 rounded-full bg-white/90"></div>
                                    </div>
                                    <div class="h-4 w-24 rounded-full bg-white/90"></div>
                                </div>
                                <div class="mt-6 h-6 w-24 rounded-full bg-white/90"></div>
                                <div class="mt-6 space-y-3">
                                    <div class="h-4 w-full rounded-full bg-white/90"></div>
                                    <div class="h-4 w-5/6 rounded-full bg-white/90"></div>
                                    <div class="h-4 w-2/3 rounded-full bg-white/90"></div>
                                </div>
                            </div>
                        </article>
                    ))}
                </div>
            </div>
        </section>

    {hasEvents && (
        <section id="akce" class="py-24 bg-white">
            <div class="max-w-7xl mx-auto px-4 text-center">
                <h2 class="text-3xl font-bold text-[#45225e] mb-12">Co chystáme?</h2>
                <div class="flex flex-wrap justify-center gap-8">
                    {plakaty.map((akce) => (
                        akce.data.poster && (
                            <div class="group relative w-full max-w-md">
                                <img src={akce.data.poster} alt={akce.data.title} class="w-full h-auto rounded-lg shadow-lg group-hover:shadow-2xl transition duration-300" loading="lazy" decoding="async" />
                            </div>
                        )
                    ))}
                </div>
            </div>
        </section>
    )}

    <footer id="kontakt" class="bg-slate-900 text-gray-400 pt-20 pb-10 border-t border-slate-800">
        <div class="max-w-7xl mx-auto px-4 grid md:grid-cols-3 gap-12 mb-16">
            <div class="text-center md:text-left">
                <h4 class="text-white text-lg font-bold mb-6 uppercase tracking-wider">Kontaktujte nás</h4>
                <div class="space-y-4 text-sm md:text-base">
                    <p class="flex items-center justify-center md:justify-start gap-3"><span class="text-[#ad6cdb]">📍</span> <span>{settings.address}</span></p>
                    <p class="flex items-center justify-center md:justify-start gap-3"><span class="text-[#ad6cdb]">📞</span> <a href={`tel:${settings.phone}`} class="hover:text-white transition">{settings.phone}</a></p>
                    <p class="flex items-center justify-center md:justify-start gap-3"><span class="text-[#ad6cdb]">✉️</span> <a href={`mailto:${settings.email}`} class="hover:text-white transition">{settings.email}</a></p>
                    <div class="pt-6 flex justify-center md:justify-start gap-6">
                        {settings.facebookLink && <a href={settings.facebookLink} class="text-gray-400 hover:text-[#ad6cdb] transition transform hover:scale-110">Facebook</a>}
                        {settings.instagramLink && <a href={settings.instagramLink} class="text-gray-400 hover:text-[#ad6cdb] transition transform hover:scale-110">Instagram</a>}
                    </div>
                </div>
            </div>
            <div class="text-center md:text-left">
                <h4 class="text-white text-lg font-bold mb-6 uppercase tracking-wider">Otevírací doba</h4>
                <ul class="space-y-3 inline-block text-left w-full max-w-xs">
                    {settings.openingHours && settings.openingHours.map((slot) => (
                        <li class="flex justify-between border-b border-gray-800 pb-2 text-sm">
                            <span>{slot.day}</span>
                            <span class="text-white font-medium">{slot.time}</span>
                        </li>
                    ))}
                </ul>
            </div>
            <div class="text-center md:text-left">
                 <h4 class="text-white text-lg font-bold mb-6 uppercase tracking-wider">Tady nás najdete</h4>
                 <div class="h-48 rounded-xl overflow-hidden relative group">
                    {settings.footerImage ? (
                        <img src={settings.footerImage} class="w-full h-full object-cover group-hover:scale-105 transition duration-700" alt="Kde nás najdete" loading="lazy" decoding="async" />
                    ) : (
                        <div class="w-full h-full bg-slate-800 flex items-center justify-center text-slate-600 text-sm">Nahrajte fotku v adminu</div>
                    )}
                </div>
            </div>
        </div>
        <div class="border-t border-slate-800 pt-8 text-center text-xs text-gray-600">
            <p>&copy; 2025 Rybízák Frýdek-Místek. Všechna práva vyhrazena.</p>
            {settings.companyInfo && <p class="mt-2 text-slate-700">{settings.companyInfo}</p>}
        </div>
    </footer>

    <!-- Employee profile modal -->
    <div id="empModal" class="fixed inset-0 z-[100] hidden">
        <div id="empModalOverlay" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
        <div id="empModalContainer" class="relative z-10 flex min-h-full items-center justify-center p-4 sm:p-6">
            <div id="empModalCard" class="relative w-full max-w-4xl overflow-hidden rounded-[2rem] bg-white shadow-2xl transform transition-all duration-300 translate-y-4 sm:scale-95 opacity-0">
                <button id="empModalClose" class="absolute right-4 top-4 z-20 flex h-11 w-11 items-center justify-center rounded-full bg-black/45 text-white shadow-lg backdrop-blur-sm transition hover:bg-black/65">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
                <div class="grid max-h-[min(88dvh,820px)] grid-rows-[auto_minmax(0,1fr)] overflow-hidden sm:max-h-[min(88vh,820px)] sm:grid-rows-1 sm:grid-cols-[minmax(0,0.42fr)_minmax(0,0.58fr)]">
                    <div id="empModalBanner" class="relative h-[min(30vh,200px)] shrink-0 overflow-hidden bg-gray-100 sm:h-auto sm:min-h-[min(280px,45vh)] sm:max-h-none"></div>
                    <div id="empModalBody" class="flex min-h-0 flex-col justify-start overflow-y-auto overscroll-contain px-5 pb-6 pt-5 sm:min-h-0 sm:justify-center sm:overflow-y-auto sm:px-8 sm:py-8">
                        <div id="empModalAvatarWrap" class="mb-4 text-center sm:text-left">
                            <div class="mx-auto h-20 w-20 overflow-hidden rounded-full border-4 border-white bg-gray-100 shadow-lg sm:mx-0 sm:h-24 sm:w-24">
                                <img id="empModalAvatarImg" src="" alt="" class="w-full h-full object-cover" />
                            </div>
                        </div>
                        <div class="text-center sm:text-left">
                            <h3 id="empModalName" class="text-2xl font-bold text-[#45225e]"></h3>
                            <p id="empModalPozice" class="mt-1 text-sm font-semibold uppercase tracking-wider text-[#ad6cdb]"></p>
                        </div>
                        <div id="empModalText" class="mt-4 text-pretty text-sm leading-relaxed text-gray-600"></div>
                        <div id="empModalVino" class="mt-5 hidden border-t border-gray-100 pt-4">
                            <p class="mb-3 text-xs font-bold uppercase tracking-wider text-gray-400">Oblíbené víno</p>
                            <a id="empModalVinoLink" href="#" target="_blank" rel="noopener" class="flex items-center gap-3 rounded-xl bg-gray-50 p-3 transition group hover:bg-gray-100">
                                <img id="empModalVinoImg" src="" alt="" class="h-14 w-14 flex-shrink-0 rounded-lg bg-white object-contain shadow-sm" />
                                <span id="empModalVinoNazev" class="text-sm font-semibold text-gray-800 transition group-hover:text-[#45225e]"></span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script is:inline>
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');

        btn.addEventListener('click', () => {
            menu.classList.toggle('hidden');
        });

        menu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
                menu.classList.add('hidden');
            });
        });

        (function() {
            var modal = document.getElementById('empModal');
            var card = document.getElementById('empModalCard');
            var closeBtn = document.getElementById('empModalClose');
            var banner = document.getElementById('empModalBanner');
            var avatarWrap = document.getElementById('empModalAvatarWrap');
            var avatarImg = document.getElementById('empModalAvatarImg');
            var teamSection = document.querySelector('[data-team-section]');
            var teamList = document.querySelector('[data-team-list]');
            var shiftSection = document.querySelector('[data-shift-section]');
            var shiftList = document.querySelector('[data-shift-list]');
            var reviewSection = document.querySelector('[data-reviews-section]');
            var reviewTrack = document.querySelector('[data-review-list]');
            var reviewControls = document.querySelector('[data-review-carousel-controls]');
            var prevButton = document.querySelector('[data-review-carousel-prev]');
            var nextButton = document.querySelector('[data-review-carousel-next]');
            var profiles = {};
            var lightboxRequested = false;

            function toggleBanner() {
                var bannerEl = document.querySelector('[data-banner]');
                if (!bannerEl) return;

                var now = new Date().toLocaleDateString('en-CA', { timeZone: 'Europe/Prague' });
                var start = bannerEl.getAttribute('data-banner-start');
                var end = bannerEl.getAttribute('data-banner-end');
                var visible = true;

                if (start && now < start) visible = false;
                if (end && now > end) visible = false;

                bannerEl.classList.toggle('hidden', !visible);
            }

            function escapeHtml(value) {
                return String(value || '').replace(/[&<>"']/g, function(char) {
                    return ({
                        '&': '&amp;',
                        '<': '&lt;',
                        '>': '&gt;',
                        '"': '&quot;',
                        "'": '&#39;'
                    })[char];
                });
            }

            function ensureLightbox() {
                if (lightboxRequested || !document.querySelector('[data-fslightbox]')) return;
                lightboxRequested = true;

                var script = document.createElement('script');
                script.src = 'https://cdnjs.cloudflare.com/ajax/libs/fslightbox/3.0.9/index.min.js';
                script.defer = true;
                document.body.appendChild(script);
            }

            function renderPerson(person, variant) {
                var isShift = variant === 'shift';
                var hasProfile = Boolean(person.email && profiles[person.email]);
                var wrapperClass = (isShift ? 'flex flex-col items-center' : 'flex flex-col items-center group flex-shrink-0') + (hasProfile ? ' cursor-pointer emp-profile' : '');
                var photoBoxClass = isShift ? 'w-14 h-14 md:w-16 md:h-16 mb-1.5' : 'w-20 h-20 md:w-24 md:h-24 mb-2';
                var photoHtml = person.photo
                    ? '<img src="' + escapeHtml(person.photo) + '" alt="' + escapeHtml(person.name) + '" class="relative w-full h-full rounded-full object-cover ' + (isShift ? 'border-2 border-green-300 shadow-sm' : 'border-[3px] border-white shadow-md group-hover:scale-105 transition duration-300') + '" loading="lazy" decoding="async" />'
                    : '<div class="w-full h-full bg-gray-200 rounded-full flex items-center justify-center ' + (isShift ? 'text-lg' : 'text-2xl') + '">🍷</div>';
                var positionHtml = isShift && person.pozice
                    ? '<span class="text-[10px] font-bold uppercase tracking-wider text-green-700/60 mt-0.5">' + escapeHtml(person.pozice) + '</span>'
                    : '';

                return '<div class="' + wrapperClass + '" data-email="' + escapeHtml(person.email || '') + '">' +
                    '<div class="' + photoBoxClass + ' relative">' + photoHtml + '</div>' +
                    '<span class="' + (isShift ? 'text-xs' : 'text-sm') + ' font-semibold text-gray-800">' + escapeHtml(person.name) + '</span>' +
                    positionHtml +
                '</div>';
            }

            function renderReview(review, useCarousel) {
                return '<article data-review-card class="relative h-full rounded-[2rem] border border-[#45225e]/10 bg-gradient-to-br from-[#fffaf5] via-white to-[#faf6ff] p-7 shadow-[0_8px_32px_-4px_rgba(69,34,94,0.09),0_2px_8px_-2px_rgba(69,34,94,0.06)]' + (useCarousel ? ' snap-start' : '') + '">' +
                    '<div class="absolute right-0 top-0 h-28 w-28 rounded-full bg-[#ad6cdb]/10 blur-3xl"></div>' +
                    '<div class="relative z-10 flex h-full flex-col">' +
                        '<div class="flex items-center justify-between gap-4">' +
                            '<div>' +
                                '<div class="text-lg font-bold text-[#45225e]">' + escapeHtml(review.author) + '</div>' +
                                '<span class="inline-flex items-center rounded-full bg-white/90 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.28em] text-slate-500 shadow-sm">Ověřené hodnocení</span>' +
                            '</div>' +
                            (review.publishedAt ? '<span class="text-sm font-medium text-slate-500">' + escapeHtml(review.publishedAt) + '</span>' : '') +
                        '</div>' +
                        '<div class="mt-6 flex items-center gap-3">' +
                            '<span class="select-none text-2xl font-black leading-none tracking-[0.2em] text-transparent bg-clip-text" style="background-image: linear-gradient(90deg, #f59e0b ' + (Number(review.starValue || 0) * 20) + '%, #e5e7eb ' + (Number(review.starValue || 0) * 20) + '%);" aria-hidden="true">★★★★★</span>' +
                            '<span class="text-sm font-bold text-amber-600">' + escapeHtml(review.starLabel) + ' / 5</span>' +
                        '</div>' +
                        '<p class="mt-6 flex-1 text-base leading-8 text-slate-700">"' + escapeHtml(review.comment) + '"</p>' +
                    '</div>' +
                '</article>';
            }

            function bindProfileTriggers() {
                document.querySelectorAll('.emp-profile').forEach(function(el) {
                    if (el.dataset.profileBound === 'true') return;
                    el.dataset.profileBound = 'true';
                    el.addEventListener('click', function() {
                        var email = el.getAttribute('data-email');
                        if (email) openModal(email);
                    });
                });
            }

            function getReviewScrollAmount() {
                if (!reviewTrack) return 0;
                var firstCard = reviewTrack.querySelector('[data-review-card]');
                if (!firstCard) return reviewTrack.clientWidth;

                var styles = window.getComputedStyle(reviewTrack);
                var gap = parseFloat(styles.columnGap || styles.gap || '0') || 0;
                var cardWidth = firstCard.getBoundingClientRect().width;
                var visibleCards = window.innerWidth >= 1280 ? 3 : window.innerWidth >= 768 ? 2 : 1;

                return (cardWidth + gap) * visibleCards;
            }

            function updateReviewButtons() {
                if (!reviewTrack || !prevButton || !nextButton) return;
                var maxScrollLeft = Math.max(0, reviewTrack.scrollWidth - reviewTrack.clientWidth - 4);
                prevButton.disabled = reviewTrack.scrollLeft <= 4;
                nextButton.disabled = reviewTrack.scrollLeft >= maxScrollLeft;
            }

            function setupReviewCarousel(useCarousel) {
                if (!reviewTrack || !reviewControls) return;

                reviewTrack.dataset.reviewCarousel = useCarousel ? 'true' : 'false';
                reviewTrack.className = useCarousel
                    ? 'review-scroll grid grid-flow-col auto-cols-[calc(100%-1rem)] gap-6 overflow-x-auto py-2 pb-4 snap-x snap-mandatory md:auto-cols-[calc((100%-1.5rem)/2)] xl:auto-cols-[calc((100%-3rem)/3)]'
                    : 'grid gap-6 lg:grid-cols-3';

                reviewControls.classList.toggle('hidden', !useCarousel);
                reviewControls.classList.toggle('flex', useCarousel);
                updateReviewButtons();
            }

            async function loadHomepageData() {
                try {
                    var response = await fetch('/api/homepage-dynamic');
                    if (!response.ok) return;

                    var data = await response.json();
                    profiles = data.profiles || {};

                    if (teamSection && teamList && Array.isArray(data.teamMembers) && data.teamMembers.length) {
                        teamList.innerHTML = data.teamMembers.map(function(person) {
                            return renderPerson(person, 'team');
                        }).join('');
                        teamSection.hidden = false;
                    }

                    if (shiftSection && shiftList && Array.isArray(data.onShiftNow) && data.onShiftNow.length) {
                        shiftList.innerHTML = data.onShiftNow.map(function(person) {
                            return renderPerson(person, 'shift');
                        }).join('');
                        shiftSection.hidden = false;
                    }

                    if (reviewSection && reviewTrack && Array.isArray(data.reviews) && data.reviews.length) {
                        var useCarousel = data.reviews.length > 3;
                        reviewTrack.innerHTML = data.reviews.map(function(review) {
                            return renderReview(review, useCarousel);
                        }).join('');
                        reviewSection.hidden = false;
                        setupReviewCarousel(useCarousel);
                        requestAnimationFrame(function() {
                            requestAnimationFrame(function() {
                                updateReviewButtons();
                                if (typeof window.__syncReviewCarouselButtons === 'function') {
                                    window.__syncReviewCarouselButtons();
                                }
                            });
                        });
                    }

                    bindProfileTriggers();
                    ensureLightbox();
                } catch (error) {
                    console.error('Homepage dynamic data failed', error);
                }
            }

            toggleBanner();
            ensureLightbox();

            function openModal(email) {
                var p = profiles[email];
                if (!p) return;

                var heroSrc = p.img || p.foto || '';

                banner.innerHTML = '';
                banner.classList.remove('emp-modal-banner-video');
                if (heroSrc) {
                    var isVideo = /\.(mp4|webm|mov)(\?|$)/i.test(heroSrc);
                    if (isVideo) {
                        banner.classList.add('emp-modal-banner-video');
                        var video = document.createElement('video');
                        video.src = heroSrc;
                        video.autoplay = true;
                        video.muted = true;
                        video.loop = true;
                        video.playsInline = true;
                        video.className = 'h-full w-full object-contain';
                        banner.appendChild(video);
                    } else {
                        var img = document.createElement('img');
                        img.src = heroSrc;
                        img.alt = p.name;
                        img.className = 'w-full h-full object-cover';
                        banner.appendChild(img);
                    }
                    banner.style.display = '';
                } else {
                    banner.style.display = 'none';
                }

                if (p.foto) {
                    avatarImg.src = p.foto;
                    avatarImg.alt = p.name;
                    avatarWrap.style.display = '';
                } else {
                    avatarWrap.style.display = 'none';
                }

                document.getElementById('empModalName').textContent = p.name;
                var poziceEl = document.getElementById('empModalPozice');
                poziceEl.textContent = p.pozice || '';
                poziceEl.style.display = p.pozice ? '' : 'none';

                var textEl = document.getElementById('empModalText');
                if (p.text) {
                    textEl.innerHTML = p.text;
                    textEl.style.display = '';
                } else {
                    textEl.style.display = 'none';
                }

                var vinoEl = document.getElementById('empModalVino');
                if (p.vino && p.vino.nazev) {
                    document.getElementById('empModalVinoImg').src = p.vino.obrazek || '';
                    document.getElementById('empModalVinoNazev').textContent = p.vino.nazev;
                    document.getElementById('empModalVinoLink').href = p.vino.url || '#';
                    vinoEl.classList.remove('hidden');
                } else {
                    vinoEl.classList.add('hidden');
                }

                modal.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
                requestAnimationFrame(function() {
                    requestAnimationFrame(function() {
                        card.style.opacity = '1';
                        card.style.transform = 'translateY(0) scale(1)';
                    });
                });
            }

            function closeModal() {
                card.style.opacity = '0';
                card.style.transform = 'translateY(1rem) scale(0.97)';
                setTimeout(function() {
                    modal.classList.add('hidden');
                    document.body.style.overflow = '';
                    card.style.transform = 'translateY(1rem) scale(0.95)';
                }, 250);
            }

            closeBtn.addEventListener('click', closeModal);
            modal.addEventListener('click', function(e) {
                if (!modal.classList.contains('hidden') && !card.contains(e.target)) closeModal();
            });

            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
            });
            loadHomepageData();
        })();

        (function() {
            var track = document.querySelector('[data-review-list]');
            if (!track) return;

            var prevButton = document.querySelector('[data-review-carousel-prev]');
            var nextButton = document.querySelector('[data-review-carousel-next]');

            function updateButtons() {
                if (!prevButton || !nextButton) return;

                var maxScrollLeft = Math.max(0, track.scrollWidth - track.clientWidth - 4);
                prevButton.disabled = track.scrollLeft <= 4;
                nextButton.disabled = track.scrollLeft >= maxScrollLeft;
            }

            if (prevButton) {
                prevButton.addEventListener('click', function() {
                    track.scrollBy({ left: -((window.getReviewScrollAmount && window.getReviewScrollAmount()) || track.clientWidth), behavior: 'smooth' });
                });
            }

            if (nextButton) {
                nextButton.addEventListener('click', function() {
                    track.scrollBy({ left: (window.getReviewScrollAmount && window.getReviewScrollAmount()) || track.clientWidth, behavior: 'smooth' });
                });
            }

            track.addEventListener('scroll', updateButtons, { passive: true });
            window.addEventListener('resize', updateButtons);
            window.__syncReviewCarouselButtons = updateButtons;
            if (typeof ResizeObserver !== 'undefined') {
                try {
                    new ResizeObserver(updateButtons).observe(track);
                } catch (e) {}
            }
            if (document.fonts && document.fonts.ready) {
                document.fonts.ready.then(function() {
                    updateButtons();
                });
            }
            window.getReviewScrollAmount = function() {
                var firstCard = track.querySelector('[data-review-card]');
                if (!firstCard) return track.clientWidth;
                var styles = window.getComputedStyle(track);
                var gap = parseFloat(styles.columnGap || styles.gap || '0') || 0;
                var cardWidth = firstCard.getBoundingClientRect().width;
                var visibleCards = window.innerWidth >= 1280 ? 3 : window.innerWidth >= 768 ? 2 : 1;
                return (cardWidth + gap) * visibleCards;
            };
            updateButtons();
        })();
    </script>

</body>
</html>
